Codex compatibility:
  -p and --profile are Codex profile flags. They are passed through unchanged
  and are not CodeSeeq prompt flags.
EOF
}

print_system_help() {
  cat <<EOF
Usage:
  codeseeq system add "system prompt text"
  codeseeq system add -f path/to/system-prompt.md
  codeseeq system add --file path/to/system-prompt.md
  codeseeq system view
  codeseeq system show
  codeseeq system cat
  codeseeq system remove
  codeseeq system rm
  codeseeq system clear
  codeseeq system --help

The prompt is stored at:
  ${SYSTEM_PROMPT_PATH}
EOF
}

detect_container() {
  if [[ -n "${CONTAINER:-}" ]]; then
    case "$CONTAINER" in
      podman|docker) ;;
      *) die "unsupported container runtime: ${CONTAINER}. Use CONTAINER=podman or CONTAINER=docker." ;;
    esac
    command -v "$CONTAINER" >/dev/null 2>&1 || die "container runtime not found: ${CONTAINER}"
    printf '%s\n' "$CONTAINER"
    return 0
  fi

  if command -v podman >/dev/null 2>&1; then
    printf '%s\n' podman
    return 0
  fi

  if command -v docker >/dev/null 2>&1; then
    warn "podman not found; using docker as compatible fallback"
    printf '%s\n' docker
    return 0
  fi

  die "no container runtime found. Install Podman (preferred) or Docker, or set CONTAINER=podman|docker."
}

ensure_container_runtime() {
  if [[ -n "${CONTAINER:-}" ]]; then
    return 0
  fi
  CONTAINER="$(detect_container)"
}

volume_suffix_for_runtime() {
  if [[ -n "${CODESEEQ_VOLUME_SUFFIX+x}" ]]; then
    printf '%s' "$CODESEEQ_VOLUME_SUFFIX"
    return 0
  fi
  if [[ "$CONTAINER" == "podman" ]]; then
    printf ':Z'
  fi
}

readonly_volume_suffix_for_runtime() {
  if [[ -n "${CODESEEQ_CONFIG_VOLUME_SUFFIX+x}" ]]; then
    printf '%s' "$CODESEEQ_CONFIG_VOLUME_SUFFIX"
    return 0
  fi
  if [[ "$CONTAINER" == "podman" ]]; then
    printf ':ro,Z'
  else
    printf ':ro'
  fi
}

image_exists() {
  if [[ "$CONTAINER" == "podman" ]]; then
    "$CONTAINER" image exists "$IMAGE" >/dev/null 2>&1
  else
    "$CONTAINER" image inspect "$IMAGE" >/dev/null 2>&1
  fi
}

ensure_image() {
  if image_exists; then
    return 0
  fi
  if is_truthy "$AUTO_BUILD"; then
    log "image ${IMAGE} not found; building from ${BUILD_CONTEXT} with ${CONTAINER}"
    "$CONTAINER" build -t "$IMAGE" "$BUILD_CONTEXT"
  else
    die "image ${IMAGE} missing; run: ${CONTAINER} build -t ${IMAGE} ${BUILD_CONTEXT}"
  fi
}

toml_quote_file() {
  local path="$1"
  if command -v jq >/dev/null 2>&1; then
    jq -Rs . < "$path"
  elif command -v python3 >/dev/null 2>&1; then
    python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))' < "$path"
  else
    die "jq or python3 is required to quote system prompt text for Codex config"
  fi
}

system_prompt_present() {
  [[ -f "$SYSTEM_PROMPT_PATH" && -s "$SYSTEM_PROMPT_PATH" ]]
}

system_prompt_bytes() {
  if [[ -f "$SYSTEM_PROMPT_PATH" ]]; then
    wc -c < "$SYSTEM_PROMPT_PATH" | tr -d '[:space:]'
  else
    printf '0'
  fi
}

system_prompt_lines() {
  if [[ -f "$SYSTEM_PROMPT_PATH" ]]; then
    awk 'END { print NR }' "$SYSTEM_PROMPT_PATH"
  else
    printf '0'
  fi
}

system_add() {
  local file=""
  local inline=()
  while (( $# > 0 )); do
    case "$1" in
      -f|--file)
        [[ $# -ge 2 ]] || die "system add: $1 requires a file path"
        [[ -z "$file" ]] || die "system add: only one --file value is allowed"
        file="$2"
        shift 2
        ;;
      --file=*)
        [[ -z "$file" ]] || die "system add: only one --file value is allowed"
        file="${1#--file=}"
        shift
        ;;
      --help|-h)
        print_system_help
        return 0
        ;;
      *)
        inline+=("$1")
        shift
        ;;
    esac
  done

  if [[ -n "$file" && ${#inline[@]} -gt 0 ]]; then
    die "system add: provide inline text or -f/--file, not both"
  fi
  if [[ -z "$file" && ${#inline[@]} -eq 0 ]]; then
    print_system_help >&2
    die "system add: missing inline text or -f/--file"
  fi

  mkdir -p "$(dirname "$SYSTEM_PROMPT_PATH")"
  if [[ -n "$file" ]]; then
    [[ -f "$file" ]] || die "system add: file not found: $file"
    [[ -r "$file" ]] || die "system add: file is not readable: $file"
    cp -- "$file" "$SYSTEM_PROMPT_PATH"
  else
    printf '%s' "${inline[*]}" > "$SYSTEM_PROMPT_PATH"
  fi
  chmod 600 "$SYSTEM_PROMPT_PATH" 2>/dev/null || true
  printf 'Stored CodeSeeq system prompt at %s\n' "$SYSTEM_PROMPT_PATH"
}

system_view() {
  if [[ ! -f "$SYSTEM_PROMPT_PATH" ]]; then
    printf 'No CodeSeeq system prompt configured.\n'
    printf 'Path: %s\n' "$SYSTEM_PROMPT_PATH"
    return 0
  fi
  printf 'CodeSeeq system prompt\n'
  printf 'Path: %s\n' "$SYSTEM_PROMPT_PATH"
  printf 'Bytes: %s\n' "$(system_prompt_bytes)"
  printf 'Lines: %s\n' "$(system_prompt_lines)"
  printf '%s\n' '---'
  cat "$SYSTEM_PROMPT_PATH"
  printf '\n'
}

system_remove() {
  local removed="false"
  if [[ -f "$SYSTEM_PROMPT_PATH" ]]; then
    rm -f -- "$SYSTEM_PROMPT_PATH"
    printf 'Removed CodeSeeq system prompt at %s\n' "$SYSTEM_PROMPT_PATH"
    removed="true"
  fi
  if [[ "$LEGACY_SYSTEM_PROMPT_PATH" != "$SYSTEM_PROMPT_PATH" && -f "$LEGACY_SYSTEM_PROMPT_PATH" ]]; then
    rm -f -- "$LEGACY_SYSTEM_PROMPT_PATH"
    printf 'Removed legacy CodeSeeq system prompt at %s\n' "$LEGACY_SYSTEM_PROMPT_PATH"
    removed="true"
  fi
  if [[ "$removed" != "true" ]]; then
    printf 'No CodeSeeq system prompt configured; nothing to remove.\n'
    printf 'Path: %s\n' "$SYSTEM_PROMPT_PATH"
  fi
  if [[ -f "$HOST_CODEX_HOME/config.toml" ]]; then
    local tmp
    tmp="$(mktemp "${HOST_CODEX_HOME}/config.XXXXXX")"
    awk '
      /^# CodeSeeq-managed persistent system prompt\.$/ { next }
      /^developer_instructions = / { next }
      { print }
    ' "$HOST_CODEX_HOME/config.toml" > "$tmp"
    mv "$tmp" "$HOST_CODEX_HOME/config.toml"
    chmod 600 "$HOST_CODEX_HOME/config.toml" 2>/dev/null || true
  fi
}

system_cmd() {
  local sub="${1:-}"
  [[ -z "$sub" ]] || shift
  case "$sub" in
    add) system_add "$@" ;;
    view|show|cat) system_view ;;
    remove|rm|clear) system_remove ;;
    --help|-h|"") print_system_help ;;
    *) die "unknown system subcommand: $sub" ;;
  esac
}

normalize_model() {
  local model="$1"
  local thinking_override="${2:-}"
  local alias_thinking="false"

  if [[ "$model" == deepseek/deepseek-v4-* ]]; then
    model="${model/deepseek\//deepseek@}"
  fi

  case "$model" in
    deepseek-v4-flash)
      PROVIDER_MODEL="deepseek@deepseek-v4-flash"
      alias_thinking="false"
      ;;
    deepseek-v4-flash-thinking)
      PROVIDER_MODEL="deepseek@deepseek-v4-flash"
      alias_thinking="true"
      ;;
    deepseek-v4-pro)
      PROVIDER_MODEL="deepseek@deepseek-v4-pro"
      alias_thinking="false"
      ;;
    deepseek-v4-pro-thinking)
      PROVIDER_MODEL="deepseek@deepseek-v4-pro"
      alias_thinking="true"
      ;;
    deepseek@deepseek-v4-flash)
      PROVIDER_MODEL="deepseek@deepseek-v4-flash"
      alias_thinking="false"
      ;;
    deepseek@deepseek-v4-flash-thinking)
      PROVIDER_MODEL="deepseek@deepseek-v4-flash"
      alias_thinking="true"
      ;;
    deepseek@deepseek-v4-pro)
      PROVIDER_MODEL="deepseek@deepseek-v4-pro"
      alias_thinking="false"
      ;;
    deepseek@deepseek-v4-pro-thinking)
      PROVIDER_MODEL="deepseek@deepseek-v4-pro"
      alias_thinking="true"
      ;;
    *)
      die "unsupported model: ${model}. supported choices: deepseek-v4-flash, deepseek-v4-flash-thinking, deepseek-v4-pro, deepseek-v4-pro-thinking, deepseek@deepseek-v4-flash, deepseek@deepseek-v4-pro"
      ;;
  esac

  if [[ -n "$thinking_override" ]]; then
    THINKING_EFFECTIVE="$(bool_normalize "$thinking_override")"
  else
    THINKING_EFFECTIVE="$alias_thinking"
  fi
  [[ "$THINKING_EFFECTIVE" == "true" || "$THINKING_EFFECTIVE" == "false" ]] || die "invalid thinking value: ${THINKING_EFFECTIVE}"
  CODESEEQ_MODEL="$model"
  CODESEEQ_THINKING="$THINKING_EFFECTIVE"
  if [[ "$THINKING_EFFECTIVE" == "true" ]]; then
    MODEL_SUPPORTS_REASONING_SUMMARIES="true"
    MODEL_REASONING_SUMMARY="auto"
  else
    MODEL_SUPPORTS_REASONING_SUMMARIES="false"
    MODEL_REASONING_SUMMARY="none"
  fi
  export MODEL_SUPPORTS_REASONING_SUMMARIES MODEL_REASONING_SUMMARY
}

arg_requests_danger() {
  if is_truthy "${CODESEEQ_YOLO:-false}"; then
    return 0
  fi
  if [[ "${CODESEEQ_SANDBOX_MODE:-}" == "danger-full-access" ]]; then
    return 0
  fi

  local arg next
  while (( $# > 0 )); do
    arg="$1"
    next="${2:-}"
    case "$arg" in
      -y|--yolo|--dangerously-bypass-approvals-and-sandbox)
        return 0
        ;;
      --sandbox|--sanbox|-s)
        if [[ "$next" == "danger-full-access" ]]; then
          return 0
        fi
        shift 2 || true
        continue
        ;;
      --sandbox=danger-full-access|--sanbox=danger-full-access)
        return 0
        ;;
    esac
    shift
  done
  return 1
}

first_command_arg() {
  local arg
  while (( $# > 0 )); do
    arg="$1"
    case "$arg" in
      --model|-m|--sandbox|--sanbox|-s|--prompt|-p|--cd|-C|--ask-for-approval|-a|--config|-c|--profile|--output-last-message|-o|--output-schema|--color|--image|-i|--add-dir|--enable|--disable)
        shift 2 || true
        ;;
      --model=*|--sandbox=*|--sanbox=*|--prompt=*|--cd=*|--ask-for-approval=*|--config=*|--profile=*|--output-last-message=*|--output-schema=*|--color=*|--image=*|--add-dir=*|--enable=*|--disable=*)
        shift
        ;;
      --thinking|--no-thinking|-y|--yolo|--dangerously-bypass-approvals-and-sandbox|--search|--no-alt-screen|--help|-h|--version|-V)
        printf '%s\n' "$arg"
        return 0
        ;;
      --)
        shift
        [[ $# -gt 0 ]] && printf '%s\n' "$1"
        return 0
        ;;
      -*)
        shift
        ;;
      *)
        printf '%s\n' "$arg"
        return 0
        ;;
    esac
  done
}

is_codeseeq_diagnostic_command() {
  case "$1" in
    models|doctor|config|ping|ping-stream|ping-web|ping-docs|ping-image|shell) return 0 ;;
    *) return 1 ;;
  esac
}

is_codex_subcommand() {
  case "$1" in
    exec|e|review|login|logout|mcp|plugin|mcp-server|app-server|app|completion|update|sandbox|debug|apply|a|resume|fork|cloud|exec-server|features|help|version)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

# CodeSeeq privacy hardening: block upstream Codex commands that may contact OpenAI/ChatGPT services
is_blocked_upstream_command() {
  case "$1" in
    login|logout|cloud|app|app-server|plugin|update|features|remote-control)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

block_upstream_codex_commands() {
  local cmd_arg="$1"
  if is_blocked_upstream_command "$cmd_arg"; then
    if is_truthy "${CODESEEQ_ALLOW_UPSTREAM_CODEX_SERVICES:-false}"; then
      warn "CODESEEQ_ALLOW_UPSTREAM_CODEX_SERVICES=true: allowing potentially risky upstream Codex command: ${cmd_arg}"
      return 0
    fi
    die "disabled in CodeSeeq privacy mode: this upstream Codex command may contact OpenAI/ChatGPT services or modify/update Codex state (set CODESEEQ_ALLOW_UPSTREAM_CODEX_SERVICES=true to override)"
  fi
  return 0
}

codex_option_takes_value() {
  case "$1" in
    --model|-m|--sandbox|--sanbox|-s|-p|--profile|--prompt|--cd|-C|--ask-for-approval|-a|--config|-c|--output-last-message|-o|--output-schema|--color|--image|-i|--add-dir|--enable|--disable|--remote|--remote-auth-token-env|--local-provider)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

split_direct_prompt_args() {
  DIRECT_CODEX_ARGS=()
  DIRECT_PROMPT_PARTS=()

  local arg
  while (( $# > 0 )); do
    arg="$1"
    case "$arg" in
      --)
        shift
        [[ $# -gt 0 ]] || return 1
        DIRECT_PROMPT_PARTS=("$@")
        return 0
        ;;
      --*=*)
        DIRECT_CODEX_ARGS+=("$arg")
        shift
        ;;
      -*)
        if codex_option_takes_value "$arg"; then
          [[ $# -ge 2 ]] || die "$arg requires a value"
          DIRECT_CODEX_ARGS+=("$arg" "$2")
          shift 2
        else
          DIRECT_CODEX_ARGS+=("$arg")
          shift
        fi
        ;;
      *)
        if is_codex_subcommand "$arg"; then
          return 1
        fi
        DIRECT_PROMPT_PARTS=("$@")
        return 0
        ;;
    esac
  done

  return 1
}

require_deepseek_key() {
  [[ -n "${DEEPSEEK_API_KEY:-}" ]] || die "DEEPSEEK_API_KEY is required"
  # CodeSeeq privacy hardening: OPENAI_API_KEY is no longer auto-populated from DEEPSEEK_API_KEY
}

write_host_config() {
  mkdir -p "$HOST_CODEX_HOME"
  export CODEX_HOME="$HOST_CODEX_HOME"
  cat > "$HOST_CODEX_HOME/config.toml" <<EOF
model = "${PROVIDER_MODEL}"
model_provider = "codeseeq"
model_catalog_json = "${CODESEEQ_HOST_MODEL_CATALOG_JSON:-${CODESEEQ_INSTALL_ROOT}/config/codex-model-catalog.json}"

approval_policy = "${CODESEEQ_APPROVAL_POLICY}"
sandbox_mode = "${CODESEEQ_SANDBOX_MODE}"

model_context_window = ${CODESEEQ_CONTEXT_WINDOW}
model_supports_reasoning_summaries = false
model_reasoning_summary = "none"

web_search = "live"

[analytics]
enabled = false

[feedback]
enabled = false

[otel]
exporter = "none"
metrics_exporter = "none"
trace_exporter = "none"
log_user_prompt = false

[history]
persistence = "none"
EOF

  if system_prompt_present; then
    {
      printf '\n# CodeSeeq-managed persistent system prompt.\n'
      printf 'developer_instructions = '
      toml_quote_file "$SYSTEM_PROMPT_PATH"
      printf '\n'
    } >> "$HOST_CODEX_HOME/config.toml"
  fi
  cat >> "$HOST_CODEX_HOME/config.toml" <<EOF

[model_providers.codeseeq]
name = "CodeSeeq DeepSeek Bridge"
base_url = "${CODESEEQ_OPENRESPONSES_URL}"
env_key = "DEEPSEEK_API_KEY"
wire_api = "responses"
requires_openai_auth = false
request_max_retries = ${CODESEEQ_REQUEST_MAX_RETRIES}
stream_max_retries = 2
stream_idle_timeout_ms = ${CODESEEQ_STREAM_IDLE_TIMEOUT_MS}
supports_websockets = false
EOF
  chmod 600 "$HOST_CODEX_HOME/config.toml" 2>/dev/null || true
}

container_exists_by_name() {
  local name="$1"
  "$CONTAINER" ps -a --format '{{.Names}}' 2>/dev/null | grep -Fxq "$name"
}

bridge_health_host() {
  curl --silent --show-error --fail --max-time 2 --connect-timeout 1 \
    "${CODESEEQ_OPENRESPONSES_URL%/v1}/health" >/dev/null 2>&1
}

host_port_listening() {
  local port="$1"
  if [[ -n "${CODESEEQ_TEST_BUSY_PORTS+x}" ]]; then
    case " ${CODESEEQ_TEST_BUSY_PORTS:-} " in
      *" ${port} "*) return 0 ;;
      *) return 1 ;;
    esac
  fi
  (exec 3<>"/dev/tcp/127.0.0.1/${port}") >/dev/null 2>&1
}

set_bridge_port() {
  CODESEEQ_OPENRESPONSES_PORT="$1"
  local host="${2:-127.0.0.1}"
  CODESEEQ_OPENRESPONSES_URL="http://${host}:${CODESEEQ_OPENRESPONSES_PORT}/v1"
  export CODESEEQ_OPENRESPONSES_PORT CODESEEQ_OPENRESPONSES_URL
}

set_bridge_endpoint() {
  local host="${1:-${CODESEEQ_BRIDGE_HOST:-127.0.0.1}}"
  local port="$2"
  CODESEEQ_OPENRESPONSES_PORT="$port"
  CODESEEQ_OPENRESPONSES_URL="http://${host}:${port}/v1"
  export CODESEEQ_OPENRESPONSES_PORT CODESEEQ_OPENRESPONSES_URL
}

select_host_bridge_port() {
  local start="$CODESEEQ_OPENRESPONSES_PORT"
  local limit="$CODESEEQ_OPENRESPONSES_PORT_SCAN_LIMIT"
  [[ "$start" =~ ^[0-9]+$ ]] || die "invalid CODESEEQ_OPENRESPONSES_PORT: ${start}"
  [[ "$limit" =~ ^[0-9]+$ && "$limit" -gt 0 ]] || die "invalid CODESEEQ_OPENRESPONSES_PORT_SCAN_LIMIT: ${limit}"

  local port end
  end=$((start + limit))
  for ((port = start; port < end; port++)); do
    if host_port_listening "$port"; then
      continue
    fi
    set_bridge_port "$port"
    return 0
  done

  die "no free host bridge port found in range ${start}-$((end - 1))"
}

start_bridge_container() {
  ensure_container_runtime
  ensure_image
  select_host_bridge_port

  local name="${CODESEEQ_BRIDGE_CONTAINER_NAME:-codeseeq-bridge-${CODESEEQ_OPENRESPONSES_PORT}-$$}"
  if container_exists_by_name "$name"; then
    if [[ -n "${CODESEEQ_BRIDGE_CONTAINER_NAME:-}" ]]; then
      die "bridge container name already exists: $name"
    fi
    warn "removing stale bridge container: $name"
    "$CONTAINER" rm -f "$name" >/dev/null 2>&1 || true
  fi

  local run_args=(run -d --rm --name "$name")
  if [[ "$CONTAINER" == "podman" && -n "${CODESEEQ_PODMAN_USERNS:-}" ]]; then
    run_args+=(--userns="$CODESEEQ_PODMAN_USERNS")
  fi
  run_args+=(
    -p "127.0.0.1:${CODESEEQ_OPENRESPONSES_PORT}:${CODESEEQ_OPENRESPONSES_PORT}"
    -e CODESEEQ_OPENRESPONSES_HOST=0.0.0.0
    -e "CODESEEQ_OPENRESPONSES_PORT=${CODESEEQ_OPENRESPONSES_PORT}"
  )
  local env_name
  for env_name in DEEPSEEK_API_KEY BRAVE_API_KEY UNSTRUCTURED_API_KEY DEEPSEEK_CHAT_URL CODESEEQ_BRAVE_WEB_URL UNSTRUCTURED_API_URL CODESEEQ_BRIDGE_TIMEOUT_SECONDS CODESEEQ_BRIDGE_STREAM_CHUNK_SIZE CODESEEQ_BRIDGE_TOOL_STEERING; do
    if [[ -n "${!env_name:-}" ]]; then
      run_args+=(-e "$env_name")
    fi
  done
  run_args+=(--entrypoint /usr/local/bin/codeseeq-bridge.py "$IMAGE")

  log "starting bridge container ${name} with ${CONTAINER} on ${CODESEEQ_OPENRESPONSES_URL}"
  "$CONTAINER" "${run_args[@]}" >/dev/null
  BRIDGE_CONTAINER_STARTED="$name"

  local deadline=$((SECONDS + 45))
  while (( SECONDS < deadline )); do
    if bridge_health_host; then
      return 0
    fi
    sleep 1
  done

  warn "bridge container failed to become healthy; recent logs:"
  "$CONTAINER" logs "$name" 2>&1 | tail -n 80 >&2 || true
  die "failed to start bridge container on ${CODESEEQ_OPENRESPONSES_URL}"
}

# ---------------------------------------------------------------------------
# Bridge mode abstraction (process / container / external / auto)
# ---------------------------------------------------------------------------

bridge_mode_resolve() {
  local mode="${CODESEEQ_BRIDGE_MODE:-auto}"
  case "$mode" in
    auto|process|container|external) printf '%s' "$mode" ;;
    *) die "invalid CODESEEQ_BRIDGE_MODE: $mode (use auto, process, container, or external)" ;;
  esac
}

runtime_mode_resolve() {
  local mode="${CODESEEQ_RUNTIME_MODE:-auto}"
  case "$mode" in
    auto|host|container) printf '%s' "$mode" ;;
    *) die "invalid CODESEEQ_RUNTIME_MODE: $mode (use auto, host, or container)" ;;
  esac
}

bridge_check_deps_process() {
  command -v python3 >/dev/null 2>&1 || return 1
  [[ -f "${CODESEEQ_INSTALL_ROOT}/bin/codeseeq-bridge.py" ]] || return 1
  python3 -c 'import fastapi, uvicorn, httpx' >/dev/null 2>&1 || return 1
  return 0
}

bridge_resolve_log_pid_paths() {
  if [[ -z "${CODESEEQ_BRIDGE_LOG:-}" ]]; then
    CODESEEQ_BRIDGE_LOG="${HOST_CODEX_HOME}/log/bridge.log"
  fi
  if [[ -z "${CODESEEQ_BRIDGE_PID_FILE:-}" ]]; then
    CODESEEQ_BRIDGE_PID_FILE="${HOST_CODEX_HOME}/run/bridge.pid"
  fi
  mkdir -p "$(dirname "$CODESEEQ_BRIDGE_LOG")" "$(dirname "$CODESEEQ_BRIDGE_PID_FILE")" 2>/dev/null || true
}

bridge_start_process() {
  bridge_resolve_log_pid_paths

  local host="${CODESEEQ_BRIDGE_HOST:-127.0.0.1}"

  if [[ -n "${CODESEEQ_BRIDGE_PORT:-}" ]]; then
    set_bridge_endpoint "$host" "$CODESEEQ_BRIDGE_PORT"
  else
    select_host_bridge_port
    set_bridge_endpoint "$host" "$CODESEEQ_OPENRESPONSES_PORT"
  fi

  # Reuse existing healthy bridge if CODESEEQ_BRIDGE_REUSE=1
  if is_truthy "${CODESEEQ_BRIDGE_REUSE:-0}"; then
    if bridge_healthcheck_url "http://${host}:${CODESEEQ_OPENRESPONSES_PORT}${CODESEEQ_BRIDGE_HEALTH_PATH}"; then
      log "reusing existing bridge at http://${host}:${CODESEEQ_OPENRESPONSES_PORT}"
      BRIDGE_OWNED=""
      return 0
    fi
    log "bridge reuse enabled but no healthy bridge found at http://${host}:${CODESEEQ_OPENRESPONSES_PORT}; starting new one"
  fi

  if [[ "$host" != "127.0.0.1" && "$host" != "localhost" ]]; then
    warn "bridge binding to non-loopback address: ${host}"
    if [[ "$host" == "0.0.0.0" ]]; then
      warn "CODESEEQ_BRIDGE_HOST=0.0.0.0 exposes the bridge to the network"
    fi
  fi

  # Client-facing URL: use 127.0.0.1 when bridge binds to 0.0.0.0 (unless explicit base URL)
  if [[ "$host" == "0.0.0.0" && -z "${CODESEEQ_BRIDGE_BASE_URL:-}" ]]; then
    CODESEEQ_OPENRESPONSES_URL="http://127.0.0.1:${CODESEEQ_OPENRESPONSES_PORT}/v1"
  fi
  log "bridge mode=process starting python3 on http://${host}:${CODESEEQ_OPENRESPONSES_PORT}"
  log "bridge log: ${CODESEEQ_BRIDGE_LOG}"

  CODESEEQ_BRIDGE_HOST="$host"   CODESEEQ_BRIDGE_PORT="$CODESEEQ_OPENRESPONSES_PORT"   python3 "${CODESEEQ_INSTALL_ROOT}/bin/codeseeq-bridge.py"     >> "$CODESEEQ_BRIDGE_LOG" 2>&1 &

  BRIDGE_PID=$!
  echo "$BRIDGE_PID" > "$CODESEEQ_BRIDGE_PID_FILE"
  BRIDGE_OWNED="process"

  local deadline=$((SECONDS + CODESEEQ_BRIDGE_STARTUP_TIMEOUT))
  while (( SECONDS < deadline )); do
    if bridge_healthcheck_url "http://${host}:${CODESEEQ_OPENRESPONSES_PORT}${CODESEEQ_BRIDGE_HEALTH_PATH}"; then
      log "bridge process healthy (pid=${BRIDGE_PID})"
      return 0
    fi
    if ! kill -0 "$BRIDGE_PID" >/dev/null 2>&1; then
      warn "bridge process exited early; last log lines:"
      tail -n 40 "$CODESEEQ_BRIDGE_LOG" >&2 || true
      die "bridge process exited before becoming healthy on http://${host}:${CODESEEQ_OPENRESPONSES_PORT}"
    fi
    sleep 1
  done

  warn "bridge process health check timed out after ${CODESEEQ_BRIDGE_STARTUP_TIMEOUT}s"
  tail -n 40 "$CODESEEQ_BRIDGE_LOG" >&2 || true
  die "bridge process health check timed out on http://${host}:${CODESEEQ_OPENRESPONSES_PORT}"
}

bridge_stop_owned_process() {
  if [[ "$BRIDGE_OWNED" != "process" || -z "${BRIDGE_PID:-}" ]]; then
    return 0
  fi

  log "stopping owned bridge process (pid=${BRIDGE_PID})"
  kill "$BRIDGE_PID" 2>/dev/null || true

  local waited=0
  while (( waited < 5 )); do
    if ! kill -0 "$BRIDGE_PID" >/dev/null 2>&1; then
      break
    fi
    sleep 1
    waited=$((waited + 1))
  done

  if kill -0 "$BRIDGE_PID" >/dev/null 2>&1; then
    kill -9 "$BRIDGE_PID" 2>/dev/null || true
  fi

  rm -f "$CODESEEQ_BRIDGE_PID_FILE" 2>/dev/null || true
}

bridge_healthcheck_url() {
  local url="${1:-}"
  [[ -n "$url" ]] || url="http://${CODESEEQ_BRIDGE_HOST:-127.0.0.1}:${CODESEEQ_OPENRESPONSES_PORT}${CODESEEQ_BRIDGE_HEALTH_PATH}"
  curl --silent --show-error --fail --max-time 2 --connect-timeout 1 "$url" >/dev/null 2>&1
}

bridge_start() {
  local mode
  mode="$(bridge_mode_resolve)"

  log "bridge mode: ${mode}"

  case "$mode" in
    external)
      if [[ -n "${CODESEEQ_BRIDGE_BASE_URL:-}" ]]; then
        CODESEEQ_OPENRESPONSES_URL="$CODESEEQ_BRIDGE_BASE_URL"
        local ext_health_root
        if [[ "$CODESEEQ_OPENRESPONSES_URL" == */v1/ ]]; then
          ext_health_root="${CODESEEQ_OPENRESPONSES_URL%/v1/}"
        elif [[ "$CODESEEQ_OPENRESPONSES_URL" == */v1 ]]; then
          ext_health_root="${CODESEEQ_OPENRESPONSES_URL%/v1}"
        else
          ext_health_root="${CODESEEQ_OPENRESPONSES_URL%/}"
        fi
        log "bridge external mode: using ${CODESEEQ_OPENRESPONSES_URL}"
        if bridge_healthcheck_url "${ext_health_root}${CODESEEQ_BRIDGE_HEALTH_PATH}" ||
           bridge_healthcheck_url "${ext_health_root}/health"; then
          return 0
        fi
        die "external bridge health check failed at ${CODESEEQ_OPENRESPONSES_URL}"
      fi
      die "CODESEEQ_BRIDGE_MODE=external requires CODESEEQ_BRIDGE_BASE_URL to be set"
      ;;
    process)
      if ! bridge_check_deps_process; then
        die "process bridge mode requires: python3, bin/codeseeq-bridge.py, and Python packages (fastapi, uvicorn, httpx). Install with: python3 -m pip install -r requirements-bridge.txt"
      fi
      bridge_start_process
      ;;
    container)
      ensure_container_runtime
      start_bridge_container
      ;;
    auto)
      if bridge_check_deps_process; then
        if bridge_start_process; then
          return 0
        fi
        log "process bridge failed (check logs for details)"
        if [[ "${CODESEEQ_BRIDGE_MODE:-auto}" == "auto" ]]; then
          log "auto mode: falling back to container"
          ensure_container_runtime
          start_bridge_container
          return 0
        fi
        die "process bridge failed and mode is not auto; refusing to fall back silently"
      fi
      log "auto mode: process deps not available; trying container"
      ensure_container_runtime
      start_bridge_container
      ;;
  esac
}

bridge_select_port() {
  if [[ -n "${CODESEEQ_BRIDGE_PORT:-}" ]]; then
    set_bridge_port "$CODESEEQ_BRIDGE_PORT"
    return 0
  fi
  select_host_bridge_port
}


prepare_prompt_temp_from_text() {
  mkdir -p "$HOST_CODEX_HOME/tmp"
  local tmp tmp_base
  tmp_base="$(mktemp "${HOST_CODEX_HOME}/tmp/run-prompt-XXXXXX")"
  mv "$tmp_base" "${tmp_base}.md"
  tmp="${tmp_base}.md"
  printf '%s' "$1" > "$tmp"
  chmod 600 "$tmp" 2>/dev/null || true
  TMP_FILES+=("$tmp")
  printf '%s\n' "$tmp"
}

parse_run_prompt() {
  RUN_PROMPT_FILE=""
  RUN_PROMPT_TEXT=""
  RUN_EXTRA_ARGS=()
  local inline=()
  local arg
  while (( $# > 0 )); do
    arg="$1"
    case "$arg" in
      -f|--file)
        [[ $# -ge 2 ]] || die "run: $arg requires a file path"
        [[ -z "$RUN_PROMPT_FILE" ]] || die "run: only one prompt file may be provided"
        RUN_PROMPT_FILE="$2"
        shift 2
        ;;
      --file=*)
        [[ -z "$RUN_PROMPT_FILE" ]] || die "run: only one prompt file may be provided"
        RUN_PROMPT_FILE="${arg#--file=}"
        shift
        ;;
      --model|-m)
        [[ $# -ge 2 ]] || die "run: $arg requires a value"
        CODESEEQ_MODEL="$2"
        shift 2
        ;;
      --model=*)
        CODESEEQ_MODEL="${arg#--model=}"
        shift
        ;;
      --runtime-mode)
        [[ $# -ge 2 ]] || die "run: $arg requires a value"
        CODESEEQ_RUNTIME_MODE="$2"
        shift 2
        ;;
      --runtime-mode=*)
        CODESEEQ_RUNTIME_MODE="${arg#--runtime-mode=}"
        shift
        ;;
      --bridge-mode)
        [[ $# -ge 2 ]] || die "run: $arg requires a value"
        CODESEEQ_BRIDGE_MODE="$2"
        shift 2
        ;;
      --bridge-mode=*)
        CODESEEQ_BRIDGE_MODE="${arg#--bridge-mode=}"
        shift
        ;;
      --bridge-url)
        [[ $# -ge 2 ]] || die "run: $arg requires a value"
        CODESEEQ_BRIDGE_BASE_URL="$2"
        shift 2
        ;;
      --bridge-url=*)
        CODESEEQ_BRIDGE_BASE_URL="${arg#--bridge-url=}"
        shift
        ;;
      --bridge-port)
        [[ $# -ge 2 ]] || die "run: $arg requires a value"
        CODESEEQ_BRIDGE_PORT="$2"
        shift 2
        ;;
      --bridge-port=*)
        CODESEEQ_BRIDGE_PORT="${arg#--bridge-port=}"
        shift
        ;;
      --bridge-host)
        [[ $# -ge 2 ]] || die "run: $arg requires a value"
        CODESEEQ_BRIDGE_HOST="$2"
        shift 2
        ;;
      --bridge-host=*)
        CODESEEQ_BRIDGE_HOST="${arg#--bridge-host=}"
        shift
        ;;
      --bridge-reuse)
        CODESEEQ_BRIDGE_REUSE=1
        shift
        ;;
      --no-bridge-reuse)
        CODESEEQ_BRIDGE_REUSE=0
        shift
        ;;
      --thinking)
        CODESEEQ_THINKING="true"
        shift
        ;;
      --no-thinking)
        CODESEEQ_THINKING="false"
        shift
        ;;
      -y|--yolo|--dangerously-bypass-approvals-and-sandbox)
        shift
        ;;
      --sandbox|--sanbox|-s)
        [[ $# -ge 2 ]] || die "run: $arg requires a value"
        shift 2
        ;;
      --sandbox=*|--sanbox=*)
        shift
        ;;
      -p|--profile|--prompt|--cd|-C|--ask-for-approval|-a|--config|-c|--output-last-message|-o|--output-schema|--color|--image|-i|--add-dir|--enable|--disable)
        [[ $# -ge 2 ]] || die "run: $arg requires a value"
        RUN_EXTRA_ARGS+=("$arg" "$2")
        shift 2
        ;;
      --profile=*|--prompt=*|--cd=*|--ask-for-approval=*|--config=*|--output-last-message=*|--output-schema=*|--color=*|--image=*|--add-dir=*|--enable=*|--disable=*)
        RUN_EXTRA_ARGS+=("$arg")
        shift
        ;;
      --)
        shift
        while (( $# > 0 )); do
          inline+=("$1")
          shift
        done
        ;;
      -*)
        RUN_EXTRA_ARGS+=("$1")
        shift
        ;;
      *)
        inline+=("$1")
        shift
        ;;
    esac
  done

  if [[ -n "$RUN_PROMPT_FILE" && ${#inline[@]} -gt 0 ]]; then
    die "run: provide either -f/--file or inline prompt text, not both"
  fi
  if [[ -z "$RUN_PROMPT_FILE" && ${#inline[@]} -eq 0 ]]; then
    die "run requires a prompt or -f/--file"
  fi
  if [[ -n "$RUN_PROMPT_FILE" ]]; then
    [[ -f "$RUN_PROMPT_FILE" ]] || die "run: prompt file not found: $RUN_PROMPT_FILE"
    [[ -r "$RUN_PROMPT_FILE" ]] || die "run: prompt file is not readable: $RUN_PROMPT_FILE"
  else
    RUN_PROMPT_TEXT="${inline[*]}"
  fi
}

rewrite_safe_run_file_args() {
  PREPARED_ARGS=("$@")
  [[ "${1:-}" == "run" ]] || return 0
  shift

  local prompt_file=""
  local inline=()
  local out=(run)
  local arg
  while (( $# > 0 )); do
    arg="$1"
    case "$arg" in
      -f|--file)
        [[ $# -ge 2 ]] || die "run: $arg requires a file path"
        [[ -z "$prompt_file" ]] || die "run: only one prompt file may be provided"
        prompt_file="$2"
        shift 2
        ;;
      --file=*)
        [[ -z "$prompt_file" ]] || die "run: only one prompt file may be provided"
        prompt_file="${arg#--file=}"
        shift
        ;;
      --model|-m|--sandbox|--sanbox|-s|-p|--profile|--prompt|--output-last-message|-o|--output-schema|--color|--config|-c|--enable|--disable|--image|-i|--cd|-C|--add-dir|--ask-for-approval|-a)
        [[ $# -ge 2 ]] || die "run: $arg requires a value"
        out+=("$arg" "$2")
        shift 2
        ;;
      --model=*|--sandbox=*|--sanbox=*|--profile=*|--prompt=*|--output-last-message=*|--output-schema=*|--color=*|--config=*|--enable=*|--disable=*|--image=*|--cd=*|--add-dir=*|--ask-for-approval=*)
        out+=("$arg")
        shift
        ;;
      --thinking|--no-thinking|--json|--search|--no-alt-screen)
        out+=("$arg")
        shift
        ;;
      -*)
        out+=("$arg")
        shift
        ;;
      *)
        inline+=("$arg")
        out+=("$arg")
        shift
        ;;
    esac
  done

  if [[ -n "$prompt_file" && ${#inline[@]} -gt 0 ]]; then
    die "run: provide either -f/--file or inline prompt text, not both"
  fi
  if [[ -z "$prompt_file" && ${#inline[@]} -eq 0 ]]; then
    die "run requires a prompt or -f/--file"
  fi
  [[ -n "$prompt_file" ]] || return 0
  [[ -f "$prompt_file" ]] || die "run: prompt file not found: $prompt_file"
  [[ -r "$prompt_file" ]] || die "run: prompt file is not readable: $prompt_file"

  mkdir -p "${HOST_CODEX_HOME}/tmp"
  local tmp tmp_base basename container_prompt
  tmp_base="$(mktemp "${HOST_CODEX_HOME}/tmp/run-prompt-XXXXXX")"
  mv "$tmp_base" "${tmp_base}.md"
  tmp="${tmp_base}.md"
  cp -- "$prompt_file" "$tmp"
  chmod 600 "$tmp" 2>/dev/null || true
  TMP_FILES+=("$tmp")
  basename="$(basename "$tmp")"
  container_prompt="${WORKDIR_CONTAINER}/.codeseeq/tmp/${basename}"
  CODESEEQ_RUN_PROMPT_FILE="$container_prompt"

  PREPARED_ARGS=(run --file "$container_prompt" "${out[@]:1}")
}

collect_env() {
  CONTAINER_ENV_ARGS=()

  local name
  for name in \
    DEEPSEEK_API_KEY \
    BRAVE_API_KEY \
    UNSTRUCTURED_API_KEY \
    RESPONSES_API_KEY \
    DEEPSEEK_CHAT_URL \
    CODESEEQ_BRAVE_WEB_URL \
    UNSTRUCTURED_API_URL; do
    if [[ -n "${!name:-}" ]]; then
      CONTAINER_ENV_ARGS+=(-e "$name")
    fi
  done

  CONTAINER_ENV_ARGS+=(
    -e "CODESEEQ_MODEL=${CODESEEQ_MODEL}"
    -e "CODESEEQ_THINKING=${CODESEEQ_THINKING}"
    -e "CODESEEQ_APPROVAL_POLICY=${CODESEEQ_APPROVAL_POLICY}"
    -e "CODESEEQ_SANDBOX_MODE=${CODESEEQ_SANDBOX_MODE}"
    -e "CODESEEQ_YOLO=${CODESEEQ_YOLO:-false}"
    -e "CODESEEQ_HOST_WORKDIR=${WORKDIR_HOST}"
    -e "CODESEEQ_WORKDIR=${WORKDIR_CONTAINER}"
    -e "CODESEEQ_CONFIG_HOME=${CONTAINER_CONFIG_HOME}"
    -e "CODESEEQ_SYSTEM_PROMPT_FILE=${SYSTEM_PROMPT_CONTAINER_PATH}"
    -e "CODESEEQ_OPENRESPONSES_PORT=${CODESEEQ_OPENRESPONSES_PORT}"
    -e "CODESEEQ_OPENRESPONSES_URL=${CODESEEQ_OPENRESPONSES_URL}"
    -e "CODESEEQ_CONTEXT_WINDOW=${CODESEEQ_CONTEXT_WINDOW}"
    -e "CODESEEQ_MAX_OUTPUT_TOKENS=${CODESEEQ_MAX_OUTPUT_TOKENS}"
    -e "CODESEEQ_REQUEST_MAX_RETRIES=${CODESEEQ_REQUEST_MAX_RETRIES}"
    -e "CODESEEQ_STREAM_IDLE_TIMEOUT_MS=${CODESEEQ_STREAM_IDLE_TIMEOUT_MS}"
  )

  for name in \
    CODESEEQ_STREAM \
    CODESEEQ_OPENRESPONSES_HOST \
    CODESEEQ_OPENRESPONSES_CMD \
    CODESEEQ_CODEX_HOME \
    CODESEEQ_LOG_DIR \
    CODESEEQ_RUNTIME_DIR \
    CODESEEQ_WORKSPACE_BANNER \
    CODESEEQ_BRIDGE_TOOL_STEERING \
    CODESEEQ_RUN_PROMPT_FILE; do
    if [[ -n "${!name:-}" ]]; then
      CONTAINER_ENV_ARGS+=(-e "${name}=${!name}")
    fi
  done

  return 0
}

run_safe_container() {
  rewrite_safe_run_file_args "$@"
  ensure_container_runtime
  ensure_image

  local suffix volume_spec config_suffix config_volume_spec system_prompt_dir
  suffix="$(volume_suffix_for_runtime)"
  volume_spec="${WORKDIR_HOST}:${WORKDIR_CONTAINER}${suffix}"
  system_prompt_dir="$(dirname "$SYSTEM_PROMPT_PATH")"
  if [[ -d "$system_prompt_dir" ]]; then
    config_suffix="$(readonly_volume_suffix_for_runtime)"
    config_volume_spec="${system_prompt_dir}:${CONTAINER_CONFIG_HOME}${config_suffix}"
  else
    config_volume_spec=""
  fi

  local run_args=(run --rm)
  if [[ "$CONTAINER" == "podman" && -n "${CODESEEQ_PODMAN_USERNS:-}" ]]; then
    run_args+=(--userns="$CODESEEQ_PODMAN_USERNS")
  fi
  if [[ -t 0 && -t 1 ]]; then
    run_args+=(-it)
  fi
  run_args+=(-v "$volume_spec")
  if [[ -n "$config_volume_spec" ]]; then
    run_args+=(-v "$config_volume_spec")
  fi
  run_args+=(-w "$WORKDIR_CONTAINER")
  collect_env
  run_args+=("${CONTAINER_ENV_ARGS[@]}")

  if ((${#TMP_FILES[@]} > 0)); then
    "$CONTAINER" "${run_args[@]}" "$IMAGE" "${PREPARED_ARGS[@]}"
    exit $?
  fi
  exec "$CONTAINER" "${run_args[@]}" "$IMAGE" "$@"
}

run_host_codex() {
  require_deepseek_key
  command -v codex >/dev/null 2>&1 || die "host runtime requires local Codex CLI. Install it with: npm install -g @openai/codex@0.130.0 (pinned version)"

  local danger=false
  if arg_requests_danger "$@"; then
    danger=true
  fi
  if is_truthy "${CODESEEQ_YOLO:-false}"; then
    danger=true
  fi
  if [[ "${CODESEEQ_SANDBOX_MODE:-}" == "danger-full-access" ]]; then
    danger=true
  fi

  # Ensure cleanup on any exit or interrupt
  trap '_run_host_cleanup "$?"; exit "$?"' EXIT INT TERM HUP

  local raw=("$@")
  local mode="interactive"
  local prompt_file=""
  local prompt_text=""
  local codex_args=()
  local exec_args=()
  local passthrough=()
  local arg

  if [[ "${1:-}" == "run" ]]; then
    shift
    parse_run_prompt "$@"
    mode="exec"
    prompt_file="$RUN_PROMPT_FILE"
    prompt_text="$RUN_PROMPT_TEXT"
    if ((${#RUN_EXTRA_ARGS[@]} > 0)); then
      exec_args=("${RUN_EXTRA_ARGS[@]}")
    fi
  elif [[ "${1:-}" == "codex" ]]; then
    shift
    mode="passthrough"
    # CodeSeeq privacy hardening: block upstream Codex passthrough commands
    if (( ${#passthrough[@]} > 0 )); then
      block_upstream_codex_commands "${passthrough[0]}"
    fi
    passthrough=("$@")
  else
    while (( $# > 0 )); do
      arg="$1"
      case "$arg" in
        --model|-m)
          [[ $# -ge 2 ]] || die "$arg requires a value"
          CODESEEQ_MODEL="$2"
          shift 2
          ;;
        --model=*)
          CODESEEQ_MODEL="${arg#--model=}"
          shift
          ;;
        --thinking)
          CODESEEQ_THINKING="true"
          shift
          ;;
        --no-thinking)
          CODESEEQ_THINKING="false"
          shift
          ;;
        -y|--yolo|--dangerously-bypass-approvals-and-sandbox)
          shift
          ;;
        --sandbox|--sanbox|-s)
          [[ $# -ge 2 ]] || die "$arg requires a value"
          shift 2
          ;;
        --sandbox=*|--sanbox=*)
          shift
          ;;
        *)
          codex_args+=("$arg")
          shift
          ;;
      esac
    done
    if [[ "$mode" == "interactive" ]]; then
      if split_direct_prompt_args "${codex_args[@]+"${codex_args[@]}"}"; then
        mode="exec"
        exec_args=()
        if ((${#DIRECT_CODEX_ARGS[@]} > 0)); then
          exec_args=("${DIRECT_CODEX_ARGS[@]}")
        fi
        prompt_text="${DIRECT_PROMPT_PARTS[*]}"
      else
        passthrough=("${codex_args[@]+"${codex_args[@]}"}")
      fi
    fi
  fi

  normalize_model "$CODESEEQ_MODEL" "$CODESEEQ_THINKING"
  bridge_start
  write_host_config

  export CODEX_HOME="$HOST_CODEX_HOME"
  export CODESEEQ_HOST_MODE=true

  local cmd=(codex --model "$PROVIDER_MODEL")
  if [[ "$danger" == "true" ]]; then
    cmd+=(--dangerously-bypass-approvals-and-sandbox)
  else
    cmd+=(--ask-for-approval "$CODESEEQ_APPROVAL_POLICY")
    cmd+=(--sandbox "$CODESEEQ_SANDBOX_MODE")
  fi
  if [[ "$mode" == "exec" ]]; then
    if [[ -z "$prompt_file" ]]; then
      prompt_file="$(prepare_prompt_temp_from_text "$prompt_text")"
      TMP_FILES+=("$prompt_file")
    fi
    cmd+=(exec --skip-git-repo-check)
    if ((${#exec_args[@]} > 0)); then
      cmd+=("${exec_args[@]}")
    fi
    cmd+=(-)
    log "host mode: running local Codex with bridge at ${CODESEEQ_OPENRESPONSES_URL}"
    local status
    set +e
    "${cmd[@]}" < "$prompt_file"
    status=$?
    set -e
    exit $status
  fi

  log "host mode: running local Codex with bridge at ${CODESEEQ_OPENRESPONSES_URL}"
  local status
  set +e
  if ((${#passthrough[@]} > 0)); then
    "${cmd[@]}" "${passthrough[@]}"
  else
    "${cmd[@]}"
  fi
  status=$?
  set -e
  exit $status
}


cmd_nuke() {
  local install_dir="${CODESEEQ_INSTALL_DIR:-${HOME}/.config/codeseeq}"
  local bin_dir="${CODESEEQ_BIN_DIR:-${HOME}/bin}"
  local launcher="${bin_dir}/codeseeq"

  warn "This will remove:"
  warn "  - ${install_dir} (installed snapshot)"
  warn "  - ${launcher} (launcher script)"
  warn "  - ${HOME}/.codeseeq (user Codex state, if any)"
  warn ""
  warn "Your repo checkout and container images are left untouched."
  printf 'Are you sure? [y/N] ' >&2
  local reply
  read -r reply
  case "$(printf '%s' "$reply" | tr '[:upper:]' '[:lower:]')" in
    y|yes)
      rm -rf -- "${install_dir}" 2>/dev/null || true
      rm -f -- "${launcher}" 2>/dev/null || true
      rm -rf -- "${HOME}/.codeseeq" 2>/dev/null || true
      log "CodeSeeq has been nuked from your user environment."
      ;;
    *)
      log "Nuke cancelled."
      exit 0
      ;;
  esac
}

# ─────────────────────────────────────────────────────────────
# cmd_install — local install (inlined from install-local.sh)
# ─────────────────────────────────────────────────────────────
cmd_install() {
  local log_prefix="[codeseeq-install]"

  local CODESEEQ_INSTALL_DIR="${CODESEEQ_INSTALL_DIR:-${HOME}/.config/codeseeq}"
  local CODESEEQ_BIN_DIR="${CODESEEQ_BIN_DIR:-${HOME}/bin}"

  case "${CODESEEQ_INSTALL_DIR}/" in
    "${CODESEEQ_INSTALL_ROOT}/"*)
      die "CODESEEQ_INSTALL_DIR cannot be inside source repo: ${CODESEEQ_INSTALL_DIR}"
      ;;
  esac

  case "${CODESEEQ_BIN_DIR}/" in
    "${CODESEEQ_INSTALL_ROOT}/"*)
      die "CODESEEQ_BIN_DIR cannot be inside source repo: ${CODESEEQ_BIN_DIR}"
      ;;
  esac

  mkdir -p "$CODESEEQ_INSTALL_DIR" "$CODESEEQ_BIN_DIR"

  if command -v rsync >/dev/null 2>&1; then
    rsync -a --delete \
      --exclude '.git/' \
      --exclude '.codeseeq/' \
      --exclude 'system-prompt.md' \
      --exclude '.env' \
      --exclude '.env.*' \
      --exclude '.tmp-*/' \
      --exclude '.DS_Store' \
      --exclude '__pycache__/' \
      --exclude '.pytest_cache/' \
      --exclude 'node_modules/' \
      "$CODESEEQ_INSTALL_ROOT/" "$CODESEEQ_INSTALL_DIR/"
  else
    tar -C "$CODESEEQ_INSTALL_ROOT" \
      --exclude '.git' \
      --exclude '.codeseeq' \
      --exclude 'system-prompt.md' \
      --exclude '.env' \
      --exclude '.env.*' \
      --exclude '.tmp-*' \
      --exclude '.DS_Store' \
      --exclude '__pycache__' \
      --exclude '.pytest_cache' \
      --exclude 'node_modules' \
      -cf - . | tar -C "$CODESEEQ_INSTALL_DIR" -xf -
  fi

  chmod +x "$CODESEEQ_INSTALL_DIR/codeseeq" 2>/dev/null || true

  local launcher="${CODESEEQ_BIN_DIR}/codeseeq"
  cat > "$launcher" <<-LEOF
#!/usr/bin/env bash
set -Eeuo pipefail
exec "${CODESEEQ_INSTALL_DIR}/codeseeq" "\$@"
LEOF
  chmod +x "$launcher"


  # Install Codex CLI (pinned version) for host-runtime mode and local use.
  if command -v codex >/dev/null 2>&1; then
    log "codex CLI found: $(command -v codex)"
  else
    if command -v npm >/dev/null 2>&1; then
      log "installing Codex CLI (pinned version 0.130.0) ..."
      npm install -g "@openai/codex@0.130.0" || log "WARN: npm install failed; install manually: npm install -g @openai/codex@0.130.0"
    else
      log "WARN: npm not found, cannot auto-install Codex CLI."
      log "Install Node.js + npm then run: npm install -g @openai/codex@0.130.0"
    fi
  fi
  # Install Python bridge deps if python3 available
  if [[ -f "${CODESEEQ_INSTALL_DIR}/requirements-bridge.txt" ]]; then
    if command -v python3 >/dev/null 2>&1; then
      if python3 -c 'import fastapi, uvicorn, httpx' >/dev/null 2>&1; then
        log "Python bridge deps: OK"
      else
        log "installing Python bridge deps ..."
        python3 -m pip install --quiet -r "${CODESEEQ_INSTALL_DIR}/requirements-bridge.txt" || \
          log "WARN: pip install failed; install manually: python3 -m pip install -r ${CODESEEQ_INSTALL_DIR}/requirements-bridge.txt"
      fi
    else
      log "WARN: python3 not found; install manually for host/process mode: python3 -m pip install -r requirements-bridge.txt"
    fi
  fi

  log "installed repo snapshot to ${CODESEEQ_INSTALL_DIR}"
  log "installed launcher to ${launcher}"

  case ":${PATH}:" in
    *":${CODESEEQ_BIN_DIR}:"*) ;;
    *)
      log "add ${CODESEEQ_BIN_DIR} to PATH if needed"
      ;;
  esac
}

# ─────────────────────────────────────────────────────────────
# cmd_smoke — run smoke tests (inlined from scripts/smoke-all.sh)
# ─────────────────────────────────────────────────────────────
cmd_smoke() {
  local CONTAINER IMAGE MODEL PROMPT ENV_CLEAN
  CONTAINER="$(detect_container)"
  IMAGE="${IMAGE:-codeseeq:dev}"
  MODEL="${MODEL:-deepseek-v4-flash}"
  PROMPT="${PROMPT:-Return exactly: codeseeq-ok}"
  ENV_CLEAN=(env -u CODESEEQ_CODEX_HOME -u CODESEEQ_APPROVAL_POLICY -u CODESEEQ_SANDBOX_MODE -u CODESEEQ_OPENRESPONSES_HOST -u CODESEEQ_OPENRESPONSES_PORT -u CODESEEQ_OPENRESPONSES_URL)

  echo "[smoke-all] container runtime: $CONTAINER"
  if ! command -v "$CONTAINER" >/dev/null 2>&1; then
    echo "[smoke-all] FAIL: $CONTAINER not found" >&2
    exit 1
  fi

  if [[ -f .env ]]; then
    echo "[smoke-all] loading .env (read-only)"
    set -a
    source .env
    set +a
  else
    echo "[smoke-all] .env not found; live tests may be skipped"
  fi

  key_state() {
    if [[ -n "${1:-}" ]]; then
      printf 'present'
    else
      printf 'missing'
    fi
  }

  echo "[smoke-all] key presence: DEEPSEEK_API_KEY=$(key_state "${DEEPSEEK_API_KEY:-}") BRAVE_API_KEY=$(key_state "${BRAVE_API_KEY:-}") UNSTRUCTURED_API_KEY=$(key_state "${UNSTRUCTURED_API_KEY:-}")"

  echo "[smoke-all] step: inspect-openresponses"
  make inspect-openresponses

  echo "[smoke-all] step: build"
  make build CONTAINER="$CONTAINER" IMAGE="$IMAGE"

  echo "[smoke-all] step: models"
  make models CONTAINER="$CONTAINER" IMAGE="$IMAGE" MODEL="$MODEL"

  echo "[smoke-all] step: container config/doctor checks"
  "${CODESEEQ_INSTALL_ROOT}/scripts/smoke-bridge-container.sh"

  if [[ -n "${DEEPSEEK_API_KEY:-}" ]]; then
    echo "[smoke-all] step: ping"
    make ping CONTAINER="$CONTAINER" IMAGE="$IMAGE" MODEL="$MODEL"

    echo "[smoke-all] step: ping-stream"
    make ping-stream CONTAINER="$CONTAINER" IMAGE="$IMAGE" MODEL="$MODEL"

    echo "[smoke-all] step: prompt"
    "${ENV_CLEAN[@]}" make prompt CONTAINER="$CONTAINER" IMAGE="$IMAGE" MODEL="$MODEL" PROMPT="$PROMPT"

    echo "[smoke-all] step: codex container smoke"
    "${CODESEEQ_INSTALL_ROOT}/scripts/smoke-codex-container.sh"

    echo "[smoke-all] step: host cli smoke"
    "${CODESEEQ_INSTALL_ROOT}/scripts/smoke-host-cli.sh"
  else
    echo "[smoke-all] SKIP live deepseek/codex checks: DEEPSEEK_API_KEY missing"
  fi

  echo "[smoke-all] step: doctor"
  "${ENV_CLEAN[@]}" make doctor CONTAINER="$CONTAINER" IMAGE="$IMAGE" MODEL="$MODEL"

  if [[ -n "${BRAVE_API_KEY:-}" && -n "${DEEPSEEK_API_KEY:-}" ]]; then
    echo "[smoke-all] step: ping-web"
    make ping-web CONTAINER="$CONTAINER" IMAGE="$IMAGE" MODEL="$MODEL"
    CONTAINER="$CONTAINER" IMAGE="$IMAGE" CODESEEQ_MODEL="$MODEL" ./codeseeq ping-web >/dev/null
    "${CODESEEQ_INSTALL_ROOT}/scripts/smoke-openresponses-web-search.sh"
  else
    echo "[smoke-all] SKIP web search smoke"
  fi

  if [[ -n "${UNSTRUCTURED_API_KEY:-}" && -n "${DEEPSEEK_API_KEY:-}" ]]; then
    echo "[smoke-all] step: ping-docs"
    make ping-docs CONTAINER="$CONTAINER" IMAGE="$IMAGE" MODEL="$MODEL"
    CONTAINER="$CONTAINER" IMAGE="$IMAGE" CODESEEQ_MODEL="$MODEL" ./codeseeq ping-docs >/dev/null
    "${CODESEEQ_INSTALL_ROOT}/scripts/smoke-openresponses-doc-input.sh"
  else
    echo "[smoke-all] SKIP doc parsing smoke"
  fi

  if [[ -n "${DEEPSEEK_API_KEY:-}" ]]; then
    echo "[smoke-all] step: stream sanity"
    "${CODESEEQ_INSTALL_ROOT}/scripts/smoke-openresponses-stream.sh"
  fi

  echo "[smoke-all] step: model alias normalization"
  for m in deepseek-v4-flash deepseek-v4-flash-thinking deepseek-v4-pro deepseek-v4-pro-thinking; do
    out="$("$CONTAINER" run --rm -e CODESEEQ_MODEL="$m" "$IMAGE" doctor)"
    grep -q "^Model (logical): $m$" <<<"$out"
  done

  echo "[smoke-all] step: grep wrong openresponses references in operational files"
  if rg -n "masaic|openresponses/openresponses|docker.io/masaicai/open-responses" \
    README.md docs/ARCHITECTURE.md docs/SECURITY.md Dockerfile Makefile bin codeseeq config >/dev/null; then
    echo "[smoke-all] FAIL: found old/wrong OpenResponses references" >&2
    exit 1
  fi

  if [[ -f docker-compose.yml ]]; then
    echo "[smoke-all] FAIL: docker-compose.yml exists" >&2
    exit 1
  fi

  if rg -n "docker compose up|docker-compose up|compose-first|fallback compose|two-container fallback" \
    README.md docs/ARCHITECTURE.md docs/SECURITY.md Makefile codeseeq >/dev/null; then
    echo "[smoke-all] FAIL: found compose/two-container operational guidance" >&2
    exit 1
  fi

  echo "[smoke-all] step: grep .codex operational usage"
  if rg -n "/home/codeseeq/\.codex|CODESEEQ_CODEX_HOME=.*/\.codex" \
    README.md docs/ARCHITECTURE.md docs/SECURITY.md Dockerfile Makefile bin codeseeq config >/dev/null; then
    echo "[smoke-all] FAIL: found .codex in supported operational paths" >&2
    exit 1
  fi

  echo "[smoke-all] PASS"
}

# ─────────────────────────────────────────────────────────────
# cmd_package — create release zip (inlined from scripts/package.sh)
# ─────────────────────────────────────────────────────────────
cmd_package() {
  local repo_root="${CODESEEQ_INSTALL_ROOT}"

  local zip_excludes=(
    ".git/*"
    "*/.git/*"
    ".codeseeq/*"
    "*/.codeseeq/*"
    "system-prompt.md"
    "*/system-prompt.md"
    "__MACOSX/*"
    "*/__MACOSX/*"
    ".DS_Store"
    "*/.DS_Store"
    ".env"
    ".env.*"
    "*.env"
    "*.env.*"
    "prod.env"
    "production.env"
    "dist/*"
    "*/dist/*"
    "build/*"
    "*/build/*"
    "node_modules/*"
    "*/node_modules/*"
    "workspace/*"
    "*/workspace/*"
    "__pycache__/*"
    "*/__pycache__/*"
    "*.pyc"
    "logs/*"
    "*/logs/*"
    "*.log"
    "*.zip"
  )

  have_zip_cli() { command -v zip >/dev/null 2>&1; }
  have_unzip_cli() { command -v unzip >/dev/null 2>&1; }
  have_python3() { command -v python3 >/dev/null 2>&1; }

  resolve_abs_path() {
    local path="$1" dir base
    dir="$(cd "$(dirname "$path")" && pwd)"
    base="$(basename "$path")"
    printf '%s/%s' "$dir" "$base"
  }

  create_package_with_zip() {
    local output_abs="$1" output_rel=""
    if [[ "$output_abs" == "$repo_root/"* ]]; then
      output_rel="${output_abs#"$repo_root/"}"
    fi

    local -a cmd=(zip -rq "$output_abs" .)
    local pattern
    for pattern in "${zip_excludes[@]}"; do
      cmd+=(-x "$pattern")
    done
    if [[ -n "$output_rel" ]]; then
      cmd+=(-x "$output_rel")
    fi

    (
      cd "$repo_root"
      "${cmd[@]}"
      if [[ -f .env.example ]]; then
        zip -q "$output_abs" .env.example
      fi
    )
  }

  create_package_with_python() {
    local output_abs="$1" output_rel=""
    if [[ "$output_abs" == "$repo_root/"* ]]; then
      output_rel="${output_abs#"$repo_root/"}"
    fi

    CODESEEQ_REPO_ROOT="$repo_root" \
    CODESEEQ_OUTPUT_ZIP="$output_abs" \
    CODESEEQ_OUTPUT_REL="$output_rel" \
    python3 - <<-'PY'
import fnmatch, os, zipfile
from pathlib import Path
repo = Path(os.environ["CODESEEQ_REPO_ROOT"]).resolve()
out = Path(os.environ["CODESEEQ_OUTPUT_ZIP"]).resolve()
out_rel = os.environ.get("CODESEEQ_OUTPUT_REL", "")
patterns = [".git/*","*/.git/*",".codeseeq/*","*/.codeseeq/*","system-prompt.md","*/system-prompt.md","__MACOSX/*","*/__MACOSX/*",".DS_Store","*/.DS_Store",".env",".env.*","*.env","*.env.*","prod.env","production.env","dist/*","*/dist/*","build/*","*/build/*","node_modules/*","*/node_modules/*","workspace/*","*/workspace/*","__pycache__/*","*/__pycache__/*","*.pyc","logs/*","*/logs/*","*.log","*.zip"]
if out_rel: patterns.append(out_rel)
def excluded(rel):
    if rel == ".env.example": return False
    for p in patterns:
        if fnmatch.fnmatch(rel, p): return True
        if p.endswith("/*"):
            r = p[:-2]
            if rel == r or rel.startswith(r + "/") or fnmatch.fnmatch(rel, r + "/*"): return True
    return False
out.parent.mkdir(parents=True, exist_ok=True)
with zipfile.ZipFile(out, "w", compression=zipfile.ZIP_DEFLATED) as zf:
    for root, dirs, files in os.walk(repo):
        rp = Path(root)
        rr = rp.relative_to(repo).as_posix()
        if rr == ".": rr = ""
        kept = []
        for d in dirs:
            rd = f"{rr}/{d}" if rr else d
            if excluded(rd) or excluded(rd + "/dummy"): continue
            kept.append(d)
        dirs[:] = kept
        for name in files:
            rel = f"{rr}/{name}" if rr else name
            if excluded(rel): continue
            zf.write(rp / name, rel)
PY
  }

  create_package() {
    local output_zip="$1"
    mkdir -p "$(dirname "$output_zip")"
    rm -f "$output_zip"
    local output_abs
    output_abs="$(resolve_abs_path "$output_zip")"
    if have_zip_cli; then
      create_package_with_zip "$output_abs"
    elif have_python3; then
      echo "[package] zip not found; using Python 3 zipfile fallback" >&2
      create_package_with_python "$output_abs"
    else
      die "cannot create zip: install zip or python3"
    fi
    printf '%s\n' "$output_abs"
  }

  archive_entries() {
    local archive="$1"
    if have_unzip_cli; then
      unzip -Z -1 "$archive"
    elif have_python3; then
      python3 - "$archive" <<-'PY'
import sys, zipfile
with zipfile.ZipFile(sys.argv[1]) as zf:
    for name in zf.namelist(): print(name)
PY
    else
      return 1
    fi
  }

  validate_archive() {
    local archive="$1"
    [[ -f "$archive" ]] || die "archive not found: $archive"
    local tmpdir entries_file
    tmpdir="$(mktemp -d)"
    entries_file="$tmpdir/entries.txt"
    if ! archive_entries "$archive" > "$entries_file"; then
      rm -rf "$tmpdir"
      die "cannot inspect archive: $archive"
    fi
    local failures=0 entry normalized base segment_path has_env_example=0
    while IFS= read -r entry; do
      [[ -n "$entry" ]] || continue
      normalized="${entry%/}"
      base="${normalized##*/}"
      segment_path="/${normalized}/"
      if [[ "$base" == ".env.example" ]]; then has_env_example=1; continue; fi
      case "$segment_path" in
        */.git/*|*/.codeseeq/*|*/dist/*|*/workspace/*|*/__MACOSX/*|*/node_modules/*|*/__pycache__/*|*/logs/*)
          echo "[package:check:error] forbidden path in archive: $entry" >&2
          failures=$((failures + 1))
          continue;;
      esac
      case "$base" in
        .DS_Store|*.pyc|*.zip|*.log|system-prompt.md)
          echo "[package:check:error] forbidden file in archive: $entry" >&2
          failures=$((failures + 1))
          continue;;
        .env|.env.*|*.env|*.env.*|prod.env|production.env)
          echo "[package:check:error] env-like file in archive: $entry" >&2
          failures=$((failures + 1))
          continue;;
      esac
    done < "$entries_file"
    if (( has_env_example == 0 )); then
      echo "[package:check:error] .env.example is missing from archive" >&2
      failures=$((failures + 1))
    fi
    rm -rf "$tmpdir"
    if (( failures > 0 )); then
      die "archive check failed with ${failures} issue(s): $archive"
    fi
  }

  static_package_check() {
    local failures=0
    local required_patterns=(
      '".env"' '".env.*"' '"*.env"' '"*.env.*"' '"prod.env"' '"production.env"'
      '".git/*"' '"*/.git/*"' '".codeseeq/*"' '"*/.codeseeq/*"'
      '"system-prompt.md"' '"*/system-prompt.md"'
      '"__MACOSX/*"' '"*/.DS_Store"'
      '"dist/*"' '"*/dist/*"' '"build/*"' '"*/build/*"'
      '"node_modules/*"' '"*/node_modules/*"'
      '"workspace/*"' '"*/workspace/*"'
      '"__pycache__/*"' '"*/__pycache__/*"'
      '"*.pyc"' '"logs/*"' '"*/logs/*"' '"*.log"' '"*.zip"'
    )
    local pattern
    for pattern in "${required_patterns[@]}"; do
      if ! grep -Fq "$pattern" "$0" 2>/dev/null; then
        # fallback: check the original codeseeq script
        if ! grep -Fq "$pattern" "${CODESEEQ_INSTALL_ROOT}/codeseeq" 2>/dev/null; then
          echo "[package:check:error] missing package exclusion pattern: $pattern" >&2
          failures=$((failures + 1))
        fi
      fi
    done
    if [[ ! -f "${repo_root}/.env.example" ]]; then
      echo "[package:check:error] .env.example is missing from repository root" >&2
      failures=$((failures + 1))
    fi
    if (( failures > 0 )); then
      die "static package check failed with ${failures} issue(s)"
    fi
    echo "[package] archive tooling unavailable; static package check passed"
  }

  package_check() {
    local archive tmpdir
    if ! have_zip_cli && ! have_python3; then
      static_package_check
      return 0
    fi
    if ! have_unzip_cli && ! have_python3; then
      static_package_check
      return 0
    fi
    tmpdir="$(mktemp -d)"
    trap 'rm -rf "${tmpdir:-}"' EXIT
    archive="$tmpdir/codeseeq-package-check.zip"
    create_package "$archive" >/dev/null
    validate_archive "$archive"
    echo "[package] package check passed"
    rm -rf "$tmpdir"
    trap - EXIT
  }

  # Main dispatch
  case "${1:-}" in
    -h|--help)
      echo "Usage:"
      echo "  codeseeq package [output.zip]"
      echo "  codeseeq package --check"
      echo "  codeseeq package --check-archive path/to/archive.zip"
      echo ""
      echo "Creates a clean source zip from repo root."
      ;;
    --check)
      shift
      [[ $# -eq 0 ]] || { echo "ERROR: --check does not accept output path" >&2; exit 1; }
      package_check
      ;;
    --check-archive)
      shift
      [[ $# -eq 1 ]] || { echo "ERROR: --check-archive requires exactly one archive path" >&2; exit 1; }
      validate_archive "$1"
      echo "[package] archive check passed: $1"
      ;;
    *)
      [[ $# -le 1 ]] || { echo "ERROR: too many arguments" >&2; exit 1; }
      local pkg_version default_zip
      pkg_version="$(cat "${repo_root}/VERSION" 2>/dev/null || echo dev)"
      default_zip="${repo_root}/dist/codeseeq-${pkg_version}.zip"
      create_package "${1:-$default_zip}"
      ;;
  esac
}

case "${1:-}" in
  install)
    shift
    cmd_install "$@"
    exit $?
    ;;
  build)
    shift
    CONTAINER="$(detect_container)"
    "$CONTAINER" build -t "$IMAGE" "$@" "$BUILD_CONTEXT"
    exit $?
    ;;
  smoke)
    shift
    cmd_smoke "$@"
    exit $?
    ;;
  package)
    shift
    cmd_package "$@"
    exit $?
    ;;
  system)
    shift
    system_cmd "$@"
    exit $?
    ;;
  nuke)
    cmd_nuke "$@"
    exit $?
    ;;
  --help|-h)
    print_help
    exit 0
    ;;
esac

# Pre-parse CodeSeeq flags from ALL argv positions (before AND after subcommands)
_CODESEEQ_KEPT_ARGS=()
while (( $# > 0 )); do
  case "$1" in
    --bridge-mode)
      [[ $# -ge 2 ]] || die "$1 requires a value"
      CODESEEQ_BRIDGE_MODE="$2"
      shift 2
      ;;
    --bridge-mode=*)
      CODESEEQ_BRIDGE_MODE="${1#--bridge-mode=}"
      shift
      ;;
    --bridge-url)
      [[ $# -ge 2 ]] || die "$1 requires a value"
      CODESEEQ_BRIDGE_BASE_URL="$2"
      shift 2
      ;;
    --bridge-url=*)
      CODESEEQ_BRIDGE_BASE_URL="${1#--bridge-url=}"
      shift
      ;;
    --bridge-port)
      [[ $# -ge 2 ]] || die "$1 requires a value"
      CODESEEQ_BRIDGE_PORT="$2"
      shift 2
      ;;
    --bridge-port=*)
      CODESEEQ_BRIDGE_PORT="${1#--bridge-port=}"
      shift
      ;;
    --bridge-host)
      [[ $# -ge 2 ]] || die "$1 requires a value"
      CODESEEQ_BRIDGE_HOST="$2"
      shift 2
      ;;
    --bridge-host=*)
      CODESEEQ_BRIDGE_HOST="${1#--bridge-host=}"
      shift
      ;;
    --bridge-reuse)
      CODESEEQ_BRIDGE_REUSE=1
      shift
      ;;
    --no-bridge-reuse)
      CODESEEQ_BRIDGE_REUSE=0
      shift
      ;;
    -U|--uncensored-mode)
      CODESEEQ_UNCENSORED_MODE=true
      shift
      ;;
    --image-backend)
      [[ $# -ge 2 ]] || die "--image-backend requires a value (none or venice)"
      CODESEEQ_IMAGE_BACKEND="$2"
      shift 2
      ;;
    --image-backend=*)
      CODESEEQ_IMAGE_BACKEND="${1#--image-backend=}"
      shift
      ;;
    --venice-image-model)
      [[ $# -ge 2 ]] || die "--venice-image-model requires a value"
      CODESEEQ_VENICE_IMAGE_MODEL="$2"
      shift 2
      ;;
    --venice-image-model=*)
      CODESEEQ_VENICE_IMAGE_MODEL="${1#--venice-image-model=}"
      shift
      ;;
    --runtime-mode)
      [[ $# -ge 2 ]] || die "$1 requires a value"
      CODESEEQ_RUNTIME_MODE="$2"
      shift 2
      ;;
    --runtime-mode=*)
      CODESEEQ_RUNTIME_MODE="${1#--runtime-mode=}"
      shift
      ;;
    *)
      _CODESEEQ_KEPT_ARGS+=("$1")
      shift
      ;;
  esac
done
# Restore argv without consumed CodeSeeq flags
set -- "${_CODESEEQ_KEPT_ARGS[@]+"${_CODESEEQ_KEPT_ARGS[@]}"}"
unset _CODESEEQ_KEPT_ARGS


# CodeSeeq uncensored mode: load Dolfino aka Dirty D system prompt
if is_truthy "${CODESEEQ_UNCENSORED_MODE:-false}"; then
  # Prevent recursion on re-entry; unset CODESEEQ_UNCENSORED_MODE in child
  _CODESEEQ_UNCENSORED_DONE="${CODESEEQ_UNCENSORED_DONE:-false}"
  if is_truthy "$_CODESEEQ_UNCENSORED_DONE"; then
    : # already applied, skip
  else
    CODESEEQ_UNCENSORED_DONE=true
    UNCENSORED_MD="${CODESEEQ_INSTALL_ROOT}/config/uncensored.md"
    if [[ -f "$UNCENSORED_MD" ]]; then
      log "uncensored mode: loading Dolfino aka Dirty D system prompt"
      CODESEEQ_UNCENSORED_MODE=false "$SELF_PATH" system add -f "$UNCENSORED_MD"
    else
      die "uncensored.md not found at ${UNCENSORED_MD}"
    fi
  fi
fi
cmd_arg="$(first_command_arg "$@" || true)"
# CodeSeeq privacy hardening: block upstream Codex commands by default
block_upstream_codex_commands "$cmd_arg"

# Diagnostic / management commands always run via CodeSeeq, not passed to Codex
if is_codeseeq_diagnostic_command "$cmd_arg"; then
  # Host-runtime diagnostics run without container
  if [[ "${CODESEEQ_RUNTIME_MODE:-auto}" == "host" ]]; then
    case "$cmd_arg" in
      models)
        if [[ -f "${CODESEEQ_INSTALL_ROOT}/config/model-catalog.json" ]]; then
          cat "${CODESEEQ_INSTALL_ROOT}/config/model-catalog.json"
        else
          echo '{"models":[]}'
        fi
        exit 0
        ;;
      config)
        write_host_config
        printf 'Runtime: host
'
        printf 'Bridge: %s
' "${CODESEEQ_BRIDGE_MODE:-auto}"
        printf 'Config: %s/config.toml
' "$HOST_CODEX_HOME"
        exit 0
        ;;
      doctor)
        echo "CodeSeeq Doctor (host runtime)"
        echo "=============================="
        echo "Runtime mode: ${CODESEEQ_RUNTIME_MODE:-auto}"
        echo "Bridge mode: ${CODESEEQ_BRIDGE_MODE:-auto}"
        echo "Codex: $(command -v codex 2>/dev/null || echo 'not found')"
        echo "Python3: $(command -v python3 2>/dev/null || echo 'not found')"
        echo "Bridge deps: $(python3 -c 'import fastapi,uvicorn,httpx; print("OK")' 2>/dev/null || echo 'missing')"
        echo "Container runtime: $(command -v podman 2>/dev/null || command -v docker 2>/dev/null || echo 'not found')"
        echo "Host runtime runnable: $(command -v codex >/dev/null 2>&1 && command -v python3 >/dev/null 2>&1 && python3 -c 'import fastapi' 2>/dev/null && echo yes || echo no)"
        echo "DEEPSEEK_API_KEY: $( [[ -n "${DEEPSEEK_API_KEY:-}" ]] && echo set || echo missing)"
        echo "Config home: ${CODESEEQ_CONFIG_HOME:-$HOME/.config/codeseeq}"
        exit 0
        ;;
      ping*)
        echo "ping commands require bridge; use container runtime or start bridge manually"
        exit 1
        ;;
      shell)
        echo "shell requires container runtime; host runtime has no container shell"
        exit 1
        ;;
    esac
  fi
  ensure_container_runtime
  run_safe_container "$@"
  exit $?
fi

runtime_mode="$(runtime_mode_resolve)"

use_host=false
log "runtime_mode=$runtime_mode cmd_arg=$cmd_arg"
if [[ "$runtime_mode" == "host" ]]; then
  use_host=true
  log "runtime: explicit host"
elif [[ "$runtime_mode" == "auto" ]]; then
  # Check danger first
  arg_requests_danger "$@" && ! is_codeseeq_diagnostic_command "$cmd_arg" && use_host=true
  # Auto-fallback: if no container runtime available but host deps present, use host
  if [[ "$use_host" != "true" ]]; then
    if ! command -v podman >/dev/null 2>&1 && ! command -v docker >/dev/null 2>&1 && [[ -z "${CONTAINER:-}" ]]; then
      log "auto: no container runtime found, checking host deps"
      if command -v codex >/dev/null 2>&1 && bridge_check_deps_process; then
        use_host=true
        log "auto: host deps available, using host runtime"
      fi
    else
      log "auto: container runtime available, will use container"
    fi
  fi
fi

if [[ "$use_host" == "true" ]]; then
  run_host_codex "$@"
fi

ensure_container_runtime
run_safe_container "$@"
