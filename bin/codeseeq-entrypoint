#!/usr/bin/env bash
set -Eeuo pipefail

log() {
  printf '[codeseeq] %s\n' "$*" >&2
}

warn() {
  printf '[codeseeq:warn] %s\n' "$*" >&2
}

die() {
  printf '[codeseeq:error] %s\n' "$*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "required command missing: $1"
}

bool_normalize() {
  local v="${1:-}"
  local vl
  vl="$(printf '%s' "$v" | tr '[:upper:]' '[:lower:]')"
  case "$vl" in
    1|true|yes|on) printf 'true' ;;
    0|false|no|off) printf 'false' ;;
    *) printf '%s' "$v" ;;
  esac
}

key_state() {
  local v="${1:-}"
  if [[ -n "$v" ]]; then
    printf 'present'
  else
    printf 'missing'
  fi
}

toml_quote_file() {
  local path="$1"
  if command -v jq >/dev/null 2>&1; then
    jq -Rs . < "$path"
  elif command -v python3 >/dev/null 2>&1; then
    python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))' < "$path"
  else
    die "jq or python3 is required to quote system prompt text for Codex config"
  fi
}

system_prompt_present() {
  [[ -f "$CODESEEQ_SYSTEM_PROMPT_FILE" && -s "$CODESEEQ_SYSTEM_PROMPT_FILE" ]]
}

system_prompt_state() {
  if system_prompt_present; then
    printf 'present'
  else
    printf 'missing'
  fi
}

system_prompt_bytes() {
  if [[ -f "$CODESEEQ_SYSTEM_PROMPT_FILE" ]]; then
    wc -c < "$CODESEEQ_SYSTEM_PROMPT_FILE" | tr -d '[:space:]'
  else
    printf '0'
  fi
}

system_prompt_lines() {
  if [[ -f "$CODESEEQ_SYSTEM_PROMPT_FILE" ]]; then
    awk 'END { print NR }' "$CODESEEQ_SYSTEM_PROMPT_FILE"
  else
    printf '0'
  fi
}

print_workspace_banner() {
  if [[ "$(bool_normalize "${CODESEEQ_WORKSPACE_BANNER:-true}")" == "false" ]]; then
    return 0
  fi
  if [[ -n "${CODESEEQ_HOST_WORKDIR:-}" ]]; then
    {
      printf 'CodeSeeq workspace:\n'
      printf '  host: %s\n' "$CODESEEQ_HOST_WORKDIR"
      printf '  container: %s\n' "$CODESEEQ_WORKDIR"
    } >&2
  fi
}

if [[ -n "${CODESEEQ_SYSTEM_PROMPT_FILE+x}" ]]; then
  CODESEEQ_SYSTEM_PROMPT_FILE_EXPLICIT=true
else
  CODESEEQ_SYSTEM_PROMPT_FILE_EXPLICIT=false
fi

: "${CODESEEQ_MODEL:=deepseek-v4-flash}"
: "${CODESEEQ_THINKING:=}"
: "${CODESEEQ_OPENRESPONSES_HOST:=127.0.0.1}"
: "${CODESEEQ_OPENRESPONSES_PORT:=8080}"
: "${CODESEEQ_OPENRESPONSES_URL:=http://${CODESEEQ_OPENRESPONSES_HOST}:${CODESEEQ_OPENRESPONSES_PORT}/v1}"
: "${CODESEEQ_OPENRESPONSES_CMD:=/usr/local/bin/codeseeq-bridge.py}"
: "${CODESEEQ_CODEX_HOME:=/home/codeseeq/.codeseeq}"
: "${CODESEEQ_WORKDIR:=/workspace}"
: "${CODESEEQ_APPROVAL_POLICY:=on-request}"
: "${CODESEEQ_SANDBOX_MODE:=workspace-write}"
: "${CODESEEQ_STREAM:=true}"
: "${CODESEEQ_STREAM_IDLE_TIMEOUT_MS:=600000}"
: "${CODESEEQ_REQUEST_MAX_RETRIES:=2}"
: "${CODESEEQ_CONTEXT_WINDOW:=1000000}"
: "${CODESEEQ_MAX_OUTPUT_TOKENS:=384000}"
: "${CODESEEQ_RUNTIME_DIR:=/run/codeseeq}"
: "${CODESEEQ_LOG_DIR:=/var/log/codeseeq}"
: "${CODESEEQ_OPENRESPONSES_START_TIMEOUT_SECONDS:=45}"
: "${CODESEEQ_RUNTIME_MODE:=auto}"
: "${CODESEEQ_BRIDGE_MODE:=auto}"
: "${CODESEEQ_YOLO:=false}"
: "${CODESEEQ_HOST_WORKDIR:=}"

# --- Image backend configuration ---
: "${CODESEEQ_IMAGE_BACKEND:=none}"
: "${CODESEEQ_VENICE_IMAGE_MODEL:=auto}"
: "${CODESEEQ_VENICE_IMAGE_ASPECT_RATIO:=1:1}"
: "${CODESEEQ_VENICE_IMAGE_RESOLUTION:=1K}"
: "${CODESEEQ_VENICE_IMAGE_FORMAT:=webp}"
: "${CODESEEQ_VENICE_IMAGE_VARIANTS:=1}"
: "${CODESEEQ_VENICE_IMAGE_SAFE_MODE:=true}"
: "${CODESEEQ_VENICE_IMAGE_HIDE_WATERMARK:=false}"
: "${CODESEEQ_VENICE_IMAGE_SEED:=0}"
: "${CODESEEQ_VENICE_IMAGE_RETURN_BINARY:=false}"
: "${CODESEEQ_WORKSPACE_BANNER:=true}"
: "${CODESEEQ_CONFIG_HOME:=${XDG_CONFIG_HOME:-/home/codeseeq/.config}/codeseeq}"
: "${CODESEEQ_SYSTEM_PROMPT_FILE:=${CODESEEQ_CONFIG_HOME}/system-prompt.md}"
: "${CODESEEQ_SYSTEM_PROMPT_INJECTION:=codex-config-developer_instructions}"

export CODESEEQ_MODEL CODESEEQ_THINKING CODESEEQ_OPENRESPONSES_HOST CODESEEQ_OPENRESPONSES_PORT
export CODESEEQ_IMAGE_BACKEND CODESEEQ_VENICE_IMAGE_MODEL
export CODESEEQ_VENICE_IMAGE_ASPECT_RATIO CODESEEQ_VENICE_IMAGE_RESOLUTION
export CODESEEQ_VENICE_IMAGE_FORMAT CODESEEQ_VENICE_IMAGE_VARIANTS
export CODESEEQ_VENICE_IMAGE_SAFE_MODE CODESEEQ_VENICE_IMAGE_HIDE_WATERMARK
export CODESEEQ_VENICE_IMAGE_SEED CODESEEQ_VENICE_IMAGE_RETURN_BINARY
export CODESEEQ_OPENRESPONSES_URL CODESEEQ_OPENRESPONSES_CMD CODESEEQ_CODEX_HOME CODESEEQ_WORKDIR
export CODESEEQ_APPROVAL_POLICY CODESEEQ_SANDBOX_MODE CODESEEQ_STREAM CODESEEQ_STREAM_IDLE_TIMEOUT_MS
export CODESEEQ_REQUEST_MAX_RETRIES CODESEEQ_CONTEXT_WINDOW CODESEEQ_MAX_OUTPUT_TOKENS CODESEEQ_YOLO
export CODESEEQ_HOST_WORKDIR CODESEEQ_WORKSPACE_BANNER CODESEEQ_CONFIG_HOME CODESEEQ_SYSTEM_PROMPT_FILE
export CODESEEQ_SYSTEM_PROMPT_INJECTION

mkdir -p "$CODESEEQ_CODEX_HOME" "$CODESEEQ_WORKDIR" "$CODESEEQ_RUNTIME_DIR" "$CODESEEQ_LOG_DIR"
CODESEEQ_PID_FILE="$CODESEEQ_RUNTIME_DIR/openresponses.pid"
CODESEEQ_LOG_FILE="$CODESEEQ_LOG_DIR/openresponses.log"

resolve_system_prompt_file() {
  local configured="${CODESEEQ_SYSTEM_PROMPT_FILE:-}"
  local candidate
  local candidates=()

  [[ -n "$configured" ]] && candidates+=("$configured")
  if [[ "$CODESEEQ_SYSTEM_PROMPT_FILE_EXPLICIT" != "true" ]]; then
    candidates+=(
      "${CODESEEQ_WORKDIR}/.codeseeq/system-prompt.md"
      "${CODESEEQ_CODEX_HOME}/system-prompt.md"
    )
  fi

  for candidate in "${candidates[@]}"; do
    if [[ -f "$candidate" && -s "$candidate" ]]; then
      CODESEEQ_SYSTEM_PROMPT_FILE="$candidate"
      export CODESEEQ_SYSTEM_PROMPT_FILE
      return 0
    fi
  done

  if [[ -n "$configured" ]]; then
    CODESEEQ_SYSTEM_PROMPT_FILE="$configured"
  else
    CODESEEQ_SYSTEM_PROMPT_FILE="${CODESEEQ_CONFIG_HOME}/system-prompt.md"
  fi
  export CODESEEQ_SYSTEM_PROMPT_FILE
}

resolve_system_prompt_file

# Check workspace writability early.
if [[ ! -w "$CODESEEQ_WORKDIR" ]]; then
  warn "workspace ${CODESEEQ_WORKDIR} is not writable by $(id -u). host volume mapping might have permission issues."
  # Attempt a tiny test write.
  if ! touch "$CODESEEQ_WORKDIR/.codeseeq-write-test" 2>/dev/null; then
    warn "write test failed in ${CODESEEQ_WORKDIR}"
  else
    rm "$CODESEEQ_WORKDIR/.codeseeq-write-test"
    log "workspace is writable despite warning"
  fi
else
  log "workspace ${CODESEEQ_WORKDIR} is writable"
fi

MODEL_INPUT="$CODESEEQ_MODEL"
PROVIDER_MODEL=""
THINKING_EFFECTIVE=""

normalize_model() {
  local model="$1"
  local thinking_override="${2:-}"
  local alias_thinking="false"

  if [[ "$model" == deepseek/deepseek-v4-* ]]; then
    model="${model/deepseek\//deepseek@}"
  fi

  case "$model" in
    deepseek-v4-flash)
      PROVIDER_MODEL="deepseek@deepseek-v4-flash"
      alias_thinking="false"
      ;;
    deepseek-v4-flash-thinking)
      PROVIDER_MODEL="deepseek@deepseek-v4-flash"
      alias_thinking="true"
      ;;
    deepseek-v4-pro)
      PROVIDER_MODEL="deepseek@deepseek-v4-pro"
      alias_thinking="false"
      ;;
    deepseek-v4-pro-thinking)
      PROVIDER_MODEL="deepseek@deepseek-v4-pro"
      alias_thinking="true"
      ;;
    deepseek@deepseek-v4-flash)
      PROVIDER_MODEL="deepseek@deepseek-v4-flash"
      alias_thinking="false"
      ;;
    deepseek@deepseek-v4-flash-thinking)
      PROVIDER_MODEL="deepseek@deepseek-v4-flash"
      alias_thinking="true"
      ;;
    deepseek@deepseek-v4-pro)
      PROVIDER_MODEL="deepseek@deepseek-v4-pro"
      alias_thinking="false"
      ;;
    deepseek@deepseek-v4-pro-thinking)
      PROVIDER_MODEL="deepseek@deepseek-v4-pro"
      alias_thinking="true"
      ;;
    *)
      die "unsupported model: ${model}. supported choices: deepseek-v4-flash, deepseek-v4-flash-thinking, deepseek-v4-pro, deepseek-v4-pro-thinking, deepseek@deepseek-v4-flash, deepseek@deepseek-v4-pro"
      ;;
  esac

  if [[ -n "$thinking_override" ]]; then
    THINKING_EFFECTIVE="$(bool_normalize "$thinking_override")"
  else
    THINKING_EFFECTIVE="$alias_thinking"
  fi

  THINKING_EFFECTIVE="$(bool_normalize "$THINKING_EFFECTIVE")"
  if [[ "$THINKING_EFFECTIVE" != "true" && "$THINKING_EFFECTIVE" != "false" ]]; then
    die "invalid thinking value: ${THINKING_EFFECTIVE}"
  fi

  CODESEEQ_MODEL="$model"
  CODESEEQ_THINKING="$THINKING_EFFECTIVE"
  export CODESEEQ_MODEL CODESEEQ_THINKING
}

bridge_health() {
  curl --silent --show-error --fail --max-time 2 --connect-timeout 1 "${CODESEEQ_OPENRESPONSES_URL%/v1}/health" >/dev/null 2>&1
}

bridge_pid_running() {
  [[ -s "$CODESEEQ_PID_FILE" ]] || return 1
  local pid
  pid="$(cat "$CODESEEQ_PID_FILE")"
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" >/dev/null 2>&1
}

start_bridge() {
  require_cmd curl

  if bridge_health; then
    return 0
  fi

  if bridge_pid_running; then
    sleep 1
    if bridge_health; then
      return 0
    fi
  fi

  log "starting bridge with: ${CODESEEQ_OPENRESPONSES_CMD}"
  # shellcheck disable=SC2086
  bash -lc "${CODESEEQ_OPENRESPONSES_CMD}" >"$CODESEEQ_LOG_FILE" 2>&1 &
  echo "$!" > "$CODESEEQ_PID_FILE"

  local deadline=$((SECONDS + CODESEEQ_OPENRESPONSES_START_TIMEOUT_SECONDS))
  while (( SECONDS < deadline )); do
    if bridge_health; then
      return 0
    fi
    sleep 1
  done

  warn "bridge failed to become healthy"
  if [[ -f "$CODESEEQ_LOG_FILE" ]]; then
    tail -n 60 "$CODESEEQ_LOG_FILE" >&2 || true
  fi
  return 1
}

write_config() {
  export CODEX_HOME="$CODESEEQ_CODEX_HOME"

  cat > "$CODESEEQ_CODEX_HOME/config.toml" <<EOF
model = "${PROVIDER_MODEL}"
model_provider = "codeseeq"
model_catalog_json = "/etc/codeseeq/codex-model-catalog.json"

approval_policy = "${CODESEEQ_APPROVAL_POLICY}"
sandbox_mode = "${CODESEEQ_SANDBOX_MODE}"

model_context_window = ${CODESEEQ_CONTEXT_WINDOW}
model_supports_reasoning_summaries = false
model_reasoning_summary = "none"

web_search = "live"

[analytics]
enabled = false

[feedback]
enabled = false

[otel]
exporter = "none"
metrics_exporter = "none"
trace_exporter = "none"
log_user_prompt = false

[history]
persistence = "none"
EOF

  if system_prompt_present; then
    {
      printf '\n# CodeSeeq-managed persistent system prompt.\n'
      printf 'developer_instructions = '
      toml_quote_file "$CODESEEQ_SYSTEM_PROMPT_FILE"
      printf '\n'
    } >> "$CODESEEQ_CODEX_HOME/config.toml"
  fi

  cat >> "$CODESEEQ_CODEX_HOME/config.toml" <<EOF

[model_providers.codeseeq]
name = "CodeSeeq DeepSeek Bridge"
base_url = "${CODESEEQ_OPENRESPONSES_URL}"
env_key = "DEEPSEEK_API_KEY"
wire_api = "responses"
requires_openai_auth = false
request_max_retries = ${CODESEEQ_REQUEST_MAX_RETRIES}
stream_max_retries = 2
stream_idle_timeout_ms = ${CODESEEQ_STREAM_IDLE_TIMEOUT_MS}
supports_websockets = false
EOF

  chmod 600 "$CODESEEQ_CODEX_HOME/config.toml"
}

print_config() {
  write_config
  printf 'CODEX_HOME=%s\n' "$CODEX_HOME"
  printf 'Config path=%s\n' "$CODESEEQ_CODEX_HOME/config.toml"
  printf 'System prompt status=%s\n' "$(system_prompt_state)"
  printf 'System prompt path=%s\n' "$CODESEEQ_SYSTEM_PROMPT_FILE"
  printf 'System prompt bytes=%s\n' "$(system_prompt_bytes)"
  printf 'System prompt lines=%s\n' "$(system_prompt_lines)"
  printf 'System prompt injection=%s\n' "$CODESEEQ_SYSTEM_PROMPT_INJECTION"
  sed 's/^developer_instructions = .*/developer_instructions = "<redacted: CodeSeeq system prompt>"/' "$CODESEEQ_CODEX_HOME/config.toml"
}

require_deepseek_key() {
  [[ -n "${DEEPSEEK_API_KEY:-}" ]] || die "DEEPSEEK_API_KEY is required"
  # CodeSeeq privacy hardening: OPENAI_API_KEY is no longer auto-populated from DEEPSEEK_API_KEY
  # (removed per privacy hardening)
}

ping_deepseek() {
  require_deepseek_key
  start_bridge || die "failed to start bridge"

  local payload
  payload=$(cat <<EOF
{"model":"${PROVIDER_MODEL}","stream":false,"input":"Return exactly: codeseeq-ok"}
EOF
)

  local out
  out="$(curl --silent --show-error --fail \
    -H 'Content-Type: application/json' \
    -H "Authorization: Bearer ${DEEPSEEK_API_KEY}" \
    -d "$payload" \
    "${CODESEEQ_OPENRESPONSES_URL}/responses")"

  if grep -Eqi 'codeseeq-ok|codeseek-ok|codeeseq-ok' <<<"$out"; then
    echo "PONG: codeseeq-ok"
  else
    echo "$out" >&2
    die "ping response missing expected token"
  fi
}

ping_stream() {
  require_deepseek_key
  start_bridge || die "failed to start bridge"

  local payload
  payload=$(cat <<EOF
{"model":"${PROVIDER_MODEL}","stream":true,"input":"Return exactly: codeseeq-stream-ok"}
EOF
)

  local out
  out="$(curl --silent --show-error --fail \
    -N \
    -H 'Content-Type: application/json' \
    -H "Authorization: Bearer ${DEEPSEEK_API_KEY}" \
    -d "$payload" \
    "${CODESEEQ_OPENRESPONSES_URL}/responses")"

  if grep -q 'response.output_text.delta' <<<"$out" \
    && grep -q 'response.completed' <<<"$out" \
    && grep -Eqi 'codeseeq-stream-ok|codeseek-stream-ok' <<<"$out"; then
    echo "PONG-STREAM: codeseeq-stream-ok"
  else
    echo "$out" >&2
    die "streaming ping failed"
  fi
}

ping_image() {
  [[ -n "${VENICE_API_KEY:-}" ]] || die "VENICE_API_KEY is required for ping-image"
  if [[ "${CODESEEQ_IMAGE_BACKEND:-none}" != "venice" ]]; then
    die "ping-image requires CODESEEQ_IMAGE_BACKEND=venice"
  fi
  start_bridge || die "failed to start bridge"

  local payload
  payload=$(cat <<'INNEREOF'
{"model":"MODEL_PLACEHOLDER","prompt":"A red circle on white background","size":"256x256"}
INNEREOF
)
  payload="${payload/MODEL_PLACEHOLDER/${CODESEEQ_VENICE_IMAGE_MODEL:-auto}}"

  local out attempt
  for attempt in 1 2 3; do
    if out="$(curl --silent --show-error --fail       -H 'Content-Type: application/json'       -H "Authorization: Bearer ${VENICE_API_KEY}"       -d "$payload"       "${CODESEEQ_OPENRESPONSES_URL}/images/generations" 2>&1)"; then
      break
    fi
    if (( attempt == 3 )); then
      echo "$out" >&2
      die "image generation ping failed after retries"
    fi
    sleep 1
  done

  if echo "$out" | grep -q 'b64_json'; then
    echo "PONG-IMAGE: success"
  else
    echo "$out" >&2
    die "image generation ping failed: unexpected response"
  fi
}

ping_web() {
  require_deepseek_key
  [[ -n "${BRAVE_API_KEY:-}" ]] || die "BRAVE_API_KEY is required for ping-web"
  start_bridge || die "failed to start bridge"

  local payload
  payload=$(cat <<EOF
{"model":"${PROVIDER_MODEL}","stream":false,"codeseeq_tool":"web_search","query":"latest DeepSeek API update"}
EOF
)

  local out attempt
  for attempt in 1 2 3; do
    if out="$(curl --silent --show-error --fail \
      -H 'Content-Type: application/json' \
      -H "Authorization: Bearer ${DEEPSEEK_API_KEY}" \
      -d "$payload" \
      "${CODESEEQ_OPENRESPONSES_URL}/responses")"; then
      break
    fi
    if (( attempt == 3 )); then
      die "web search ping failed after retries"
    fi
    sleep 1
  done

  if grep -q 'result_count' <<<"$out"; then
    echo "PONG-WEB: success"
  else
    echo "$out" >&2
    die "web search ping failed"
  fi
}

ping_docs() {
  require_deepseek_key
  [[ -n "${UNSTRUCTURED_API_KEY:-}" ]] || die "UNSTRUCTURED_API_KEY is required for ping-docs"
  start_bridge || die "failed to start bridge"

  local payload
  payload=$(cat <<EOF
{"model":"${PROVIDER_MODEL}","stream":false,"codeseeq_tool":"doc_parse","text":"CodeSeeq parser smoke: list three nouns only."}
EOF
)

  local out attempt
  for attempt in 1 2 3; do
    if out="$(curl --silent --show-error --fail \
      -H 'Content-Type: application/json' \
      -H "Authorization: Bearer ${DEEPSEEK_API_KEY}" \
      -d "$payload" \
      "${CODESEEQ_OPENRESPONSES_URL}/responses")"; then
      break
    fi
    if (( attempt == 3 )); then
      die "doc parsing ping failed after retries"
    fi
    sleep 1
  done

  if grep -q 'elements' <<<"$out"; then
    echo "PONG-DOCS: success"
  else
    echo "$out" >&2
    die "doc parsing ping failed"
  fi
}

doctor() {
  write_config

  local deepseek_state brave_state unstructured_state stream_state health_state deepseek_provider_state
  deepseek_state="$(key_state "${DEEPSEEK_API_KEY:-}")"
  brave_state="$(key_state "${BRAVE_API_KEY:-}")"
  unstructured_state="$(key_state "${UNSTRUCTURED_API_KEY:-}")"

  if [[ "$brave_state" == "present" ]]; then
    brave_state="enabled"
  else
    brave_state="disabled"
  fi

  if [[ "$unstructured_state" == "present" ]]; then
    unstructured_state="enabled"
  else
    unstructured_state="disabled"
  fi

  stream_state="supported"
  if [[ -n "${DEEPSEEK_API_KEY:-}" ]]; then
    deepseek_provider_state="configured"
  else
    deepseek_provider_state="not-configured"
  fi

  if start_bridge && bridge_health; then
    health_state="up"
  else
    health_state="down"
  fi

  cat <<EOF
CodeSeeq Doctor
==============
Runtime mode: ${CODESEEQ_RUNTIME_MODE:-auto}
Bridge mode: ${CODESEEQ_BRIDGE_MODE:-auto}
Model (logical): ${CODESEEQ_MODEL}
Model (provider): ${PROVIDER_MODEL}
Thinking: ${CODESEEQ_THINKING}
CODEX_HOME: ${CODEX_HOME}
Config path: ${CODESEEQ_CODEX_HOME}/config.toml
Approval policy: ${CODESEEQ_APPROVAL_POLICY}
Sandbox mode: ${CODESEEQ_SANDBOX_MODE}
Yolo mode: ${CODESEEQ_YOLO}
Workspace host: ${CODESEEQ_HOST_WORKDIR:-unknown}
Workspace container: ${CODESEEQ_WORKDIR}
System prompt: $(system_prompt_state)
System prompt path: ${CODESEEQ_SYSTEM_PROMPT_FILE}
System prompt bytes: $(system_prompt_bytes)
System prompt lines: $(system_prompt_lines)
System prompt injection: ${CODESEEQ_SYSTEM_PROMPT_INJECTION}
Image backend: ${CODESEEQ_IMAGE_BACKEND:-none}
Venice image model: ${CODESEEQ_VENICE_IMAGE_MODEL:-auto}
Venice API key: $(key_state "${VENICE_API_KEY:-}")
Bridge URL: ${CODESEEQ_OPENRESPONSES_URL}
Bridge startup command: ${CODESEEQ_OPENRESPONSES_CMD}
Bridge health: ${health_state}
DeepSeek provider: ${deepseek_provider_state}
DeepSeek provider key: ${deepseek_state}
Brave web_search: ${brave_state}
Unstructured doc parsing: ${unstructured_state}
Streaming/chunked responses: ${stream_state}
Bridge implementation: bin/codeseeq-bridge.py
Runtime mode: ${CODESEEQ_RUNTIME_MODE:-auto}
Bridge mode: ${CODESEEQ_BRIDGE_MODE:-auto}
EOF
}

print_models() {
  cat /etc/codeseeq/model-catalog.json
}

run_codex_exec() {
  cd "$CODESEEQ_WORKDIR"

  local prompt_file="${CODESEEQ_RUN_PROMPT_FILE:-}"
  local inline=()
  local exec_passthrough=()
  local arg
  while (( $# > 0 )); do
    arg="$1"
    case "$arg" in
      -f|--file)
        [[ $# -ge 2 ]] || die "run: $arg requires a file path"
        [[ -z "$prompt_file" || "$prompt_file" == "$2" ]] || die "run: only one prompt file may be provided"
        prompt_file="$2"
        shift 2
        ;;
      --file=*)
        local file_arg="${arg#--file=}"
        [[ -z "$prompt_file" || "$prompt_file" == "$file_arg" ]] || die "run: only one prompt file may be provided"
        prompt_file="$file_arg"
        shift
        ;;
      --model|-m)
        [[ $# -ge 2 ]] || die "run: $arg requires a value"
        CODESEEQ_MODEL="$2"
        shift 2
        ;;
      --model=*)
        CODESEEQ_MODEL="${arg#--model=}"
        shift
        ;;
      --thinking)
        CODESEEQ_THINKING="true"
        shift
        ;;
      --no-thinking)
        CODESEEQ_THINKING="false"
        shift
        ;;
      --yolo|-y|--dangerously-bypass-approvals-and-sandbox)
        CODESEEQ_YOLO="true"
        shift
        ;;
      --sandbox|--sanbox|-s)
        [[ $# -ge 2 ]] || die "run: $arg requires a value"
        CODESEEQ_SANDBOX_MODE="$2"
        shift 2
        ;;
      --sandbox=*|--sanbox=*)
        CODESEEQ_SANDBOX_MODE="${arg#*=}"
        shift
        ;;
      --ask-for-approval|-a)
        [[ $# -ge 2 ]] || die "run: $arg requires a value"
        CODESEEQ_APPROVAL_POLICY="$2"
        shift 2
        ;;
      --ask-for-approval=*)
        CODESEEQ_APPROVAL_POLICY="${arg#--ask-for-approval=}"
        shift
        ;;
      --)
        shift
        while (( $# > 0 )); do
          inline+=("$1")
          shift
        done
        ;;
      --*=*)
        exec_passthrough+=("$arg")
        shift
        ;;
      -*)
        if codex_option_takes_value "$arg"; then
          [[ $# -ge 2 ]] || die "run: $arg requires a value"
          exec_passthrough+=("$arg" "$2")
          shift 2
        else
          exec_passthrough+=("$arg")
          shift
        fi
        ;;
      *)
        inline+=("$1")
        shift
        ;;
    esac
  done

  if [[ -n "$prompt_file" && ${#inline[@]} -gt 0 ]]; then
    die "run: provide either -f/--file or inline prompt text, not both"
  fi
  if [[ -z "$prompt_file" && ${#inline[@]} -eq 0 ]]; then
    die "run requires a prompt or -f/--file"
  fi
  if [[ -n "$prompt_file" ]]; then
    [[ -f "$prompt_file" ]] || die "run: prompt file not found: $prompt_file"
    [[ -r "$prompt_file" ]] || die "run: prompt file is not readable: $prompt_file"
  fi

  normalize_model "$CODESEEQ_MODEL" "$CODESEEQ_THINKING"
  CODESEEQ_YOLO="$(bool_normalize "$CODESEEQ_YOLO")"
  export CODESEEQ_YOLO CODESEEQ_APPROVAL_POLICY CODESEEQ_SANDBOX_MODE
  require_deepseek_key
  write_config
  start_bridge || die "failed to start bridge"

  build_codex_global_args
  build_codex_exec_args
  if ((${#exec_passthrough[@]} > 0)); then
    CODEX_EXEC_ARGS+=("${exec_passthrough[@]}")
  fi
  print_workspace_banner
  if [[ -n "$prompt_file" ]]; then
    exec codex "${CODEX_GLOBAL_ARGS[@]}" exec "${CODEX_EXEC_ARGS[@]}" - < "$prompt_file"
  fi
  local prompt
  prompt="${inline[*]}"
  exec codex "${CODEX_GLOBAL_ARGS[@]}" exec "${CODEX_EXEC_ARGS[@]}" "$prompt"
}

run_codex_interactive() {
  require_deepseek_key
  write_config
  start_bridge || die "failed to start bridge"
  cd "$CODESEEQ_WORKDIR"
  build_codex_global_args
  print_workspace_banner
  exec codex "${CODEX_GLOBAL_ARGS[@]}" "$@"
}

build_codex_global_args() {
  CODEX_GLOBAL_ARGS=(--model "$PROVIDER_MODEL")
  if [[ "$CODESEEQ_YOLO" == "true" ]]; then
    CODEX_GLOBAL_ARGS+=(--dangerously-bypass-approvals-and-sandbox)
  elif [[ "$CODESEEQ_SANDBOX_MODE" == "danger-full-access" ]]; then
    CODEX_GLOBAL_ARGS+=(--dangerously-bypass-approvals-and-sandbox)
  else
    CODEX_GLOBAL_ARGS+=(--ask-for-approval "$CODESEEQ_APPROVAL_POLICY")
    CODEX_GLOBAL_ARGS+=(--sandbox "$CODESEEQ_SANDBOX_MODE")
  fi
}

build_codex_exec_args() {
  CODEX_EXEC_ARGS=(--skip-git-repo-check)
}

codex_args_have() {
  local needle="$1"
  shift
  local arg
  for arg in "$@"; do
    [[ "$arg" == "$needle" ]] && return 0
  done
  return 1
}

is_codex_subcommand() {
  case "$1" in
    exec|e|review|login|logout|mcp|plugin|mcp-server|app-server|app|completion|update|sandbox|debug|apply|a|resume|fork|cloud|exec-server|features|help|version)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}
# CodeSeeq privacy hardening: block upstream Codex commands that may contact OpenAI/ChatGPT services
is_blocked_upstream_command() {
  case "$1" in
    login|logout|cloud|app|app-server|plugin|update|features|remote-control)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

block_upstream_codex_commands() {
  local cmd_arg="$1"
  if is_blocked_upstream_command "$cmd_arg"; then
    if [[ "$(bool_normalize "${CODESEEQ_ALLOW_UPSTREAM_CODEX_SERVICES:-false}")" == "true" ]]; then
      warn "CODESEEQ_ALLOW_UPSTREAM_CODEX_SERVICES=true: allowing potentially risky upstream Codex command: ${cmd_arg}"
      return 0
    fi
    die "disabled in CodeSeeq privacy mode: this upstream Codex command may contact OpenAI/ChatGPT services or modify/update Codex state (set CODESEEQ_ALLOW_UPSTREAM_CODEX_SERVICES=true to override)"
  fi
  return 0
}

codex_option_takes_value() {
  case "$1" in
    --model|-m|--sandbox|--sanbox|-s|-p|--profile|--prompt|--cd|-C|--ask-for-approval|-a|--config|-c|--output-last-message|-o|--output-schema|--color|--image|-i|--add-dir|--enable|--disable|--remote|--remote-auth-token-env|--local-provider)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

split_direct_prompt_args() {
  DIRECT_CODEX_ARGS=()
  DIRECT_PROMPT_PARTS=()

  local arg
  while (( $# > 0 )); do
    arg="$1"
    case "$arg" in
      --)
        shift
        [[ $# -gt 0 ]] || return 1
        DIRECT_PROMPT_PARTS=("$@")
        return 0
        ;;
      --*=*)
        DIRECT_CODEX_ARGS+=("$arg")
        shift
        ;;
      -*)
        if codex_option_takes_value "$arg"; then
          [[ $# -ge 2 ]] || die "$arg requires a value"
          DIRECT_CODEX_ARGS+=("$arg" "$2")
          shift 2
        else
          DIRECT_CODEX_ARGS+=("$arg")
          shift
        fi
        ;;
      *)
        if is_codex_subcommand "$arg"; then
          return 1
        fi
        DIRECT_PROMPT_PARTS=("$@")
        return 0
        ;;
    esac
  done

  return 1
}

run_codex_passthrough() {
  case "${1:-}" in
    --help|-h|help|--version|-V|version)
      exec codex "$@"
      ;;
  esac

  require_deepseek_key
  write_config
  start_bridge || die "failed to start bridge"
  cd "$CODESEEQ_WORKDIR"

  build_codex_global_args

  if [[ "${1:-}" == "exec" || "${1:-}" == "e" ]]; then
    local passthrough=("$@")
    if ! codex_args_have "--skip-git-repo-check" "${passthrough[@]}"; then
      passthrough=("${passthrough[0]}" --skip-git-repo-check "${passthrough[@]:1}")
    fi
    print_workspace_banner
    exec codex "${CODEX_GLOBAL_ARGS[@]}" "${passthrough[@]}"
  fi

  print_workspace_banner
  exec codex "${CODEX_GLOBAL_ARGS[@]}" "$@"
}

open_shell() {
  write_config
  start_bridge || true
  cd "$CODESEEQ_WORKDIR"
  exec bash
}

print_help() {
  cat <<'EOF'
CodeSeeq - Codex CLI wired to DeepSeek through the CodeSeeq bridge

Usage:
  codeseeq [codex-options] [prompt]
  codeseeq "prompt"
  codeseeq run "prompt"
  codeseeq run -f task.md
  codeseeq codex [args...]

Commands:
  run, models, doctor, config, ping, ping-stream, ping-web, ping-docs, ping-image, shell, codex

Safety defaults:
  approval_policy=on-request
  sandbox_mode=workspace-write

Explicit --yolo/-y maps to Codex's dangerous bypass switch.
-p and --profile are Codex profile flags, not CodeSeeq prompt flags.
EOF
}

# Parse wrapper flags before subcommand/args.
args=()
while (( $# > 0 )); do
  case "$1" in
    --model|-m)
      [[ $# -ge 2 ]] || die "--model requires a value"
      CODESEEQ_MODEL="$2"
      shift 2
      ;;
    --model=*)
      CODESEEQ_MODEL="${1#--model=}"
      shift
      ;;
    --thinking)
      CODESEEQ_THINKING="true"
      shift
      ;;
    --no-thinking)
      CODESEEQ_THINKING="false"
      shift
      ;;
    --yolo|-y)
      CODESEEQ_YOLO="true"
      shift
      ;;
    --dangerously-bypass-approvals-and-sandbox)
      CODESEEQ_YOLO="true"
      shift
      ;;
    --sandbox|--sanbox|-s)
      [[ $# -ge 2 ]] || die "$1 requires a value"
      CODESEEQ_SANDBOX_MODE="$2"
      shift 2
      ;;
    --sandbox=*|--sanbox=*)
      CODESEEQ_SANDBOX_MODE="${1#*=}"
      shift
      ;;
    --ask-for-approval|-a)
      [[ $# -ge 2 ]] || die "$1 requires a value"
      CODESEEQ_APPROVAL_POLICY="$2"
      shift 2
      ;;
    --ask-for-approval=*)
      CODESEEQ_APPROVAL_POLICY="${1#--ask-for-approval=}"
      shift
      ;;
    --)
      shift
      while (( $# > 0 )); do
        args+=("$1")
        shift
      done
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
  if (( $# == 0 )); then
    break
  fi

done

if ((${#args[@]} > 0)); then
  set -- "${args[@]}"
else
  set --
fi

CODESEEQ_YOLO="$(bool_normalize "$CODESEEQ_YOLO")"
if [[ "$CODESEEQ_YOLO" != "true" && "$CODESEEQ_YOLO" != "false" ]]; then
  die "invalid yolo value: ${CODESEEQ_YOLO}"
fi
export CODESEEQ_YOLO CODESEEQ_APPROVAL_POLICY CODESEEQ_SANDBOX_MODE

normalize_model "$CODESEEQ_MODEL" "$CODESEEQ_THINKING"
export CODEX_HOME="$CODESEEQ_CODEX_HOME"

# CodeSeeq privacy hardening: block upstream Codex commands by default
block_upstream_codex_commands "${1:-}"

case "${1:-}" in
  "")
    run_codex_interactive
    ;;
  run)
    shift
    run_codex_exec "$@"
    ;;
  ping)
    shift
    ping_deepseek
    ;;
  ping-stream)
    shift
    ping_stream
    ;;
  ping-web)
    shift
    ping_web
    ;;
  ping-image)
    shift
    ping_image
    ;;
  ping-docs)
    shift
    ping_docs
    ;;
  doctor)
    shift
    doctor
    ;;
  models)
    shift
    print_models
    ;;
  config)
    shift
    print_config
    ;;
  shell)
    shift
    open_shell
    ;;
  codex)
    shift
    run_codex_passthrough "$@"
    ;;
  --help|-h|help)
    shift || true
    print_help
    ;;
  --version|-V|version)
    shift || true
    run_codex_passthrough --version
    ;;
  *)
    if split_direct_prompt_args "$@"; then
      if ((${#DIRECT_CODEX_ARGS[@]} > 0)); then
        run_codex_exec "${DIRECT_CODEX_ARGS[@]}" -- "${DIRECT_PROMPT_PARTS[@]}"
      else
        run_codex_exec -- "${DIRECT_PROMPT_PARTS[@]}"
      fi
    else
      run_codex_passthrough "$@"
    fi
    ;;
esac
