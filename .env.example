DEEPSEEK_API_KEY=
BRAVE_API_KEY=
UNSTRUCTURED_API_KEY=
RESPONSES_API_KEY=

CODESEEQ_MODEL=deepseek-v4-flash
CODESEEQ_THINKING=false
CODESEEQ_APPROVAL_POLICY=on-request
CODESEEQ_SANDBOX_MODE=workspace-write
CODESEEQ_YOLO=false

# Podman is preferred. Set CONTAINER=docker only when Docker is the intended runtime.
CONTAINER=podman
IMAGE=codeseeq:dev
CODESEEQ_ALLOW_UPSTREAM_CODEX_SERVICES=true
CODESEEQ_RUNTIME_MODE=host
